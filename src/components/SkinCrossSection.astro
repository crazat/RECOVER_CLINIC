---
// SkinCrossSection — 학술 일러스트 톤 피부 단면도 (Phase G+ 시각 강화)
// 표피·진피·피하·근막 4층 + 그라디언트 음영 + 새살침 깊이 + 분자 노드 + 콜라겐 fibers
---
<figure class="skin-cs" aria-label="피부 단면 일러스트레이션">
  <div class="skin-cs-cap">
    <span class="skin-cs-eye">Skin Cross-Section · Figure</span>
    <h3 class="skin-cs-title">회복은 <em>진피층</em>에서 시작됩니다</h3>
    <p class="skin-cs-sub">표피의 자극이 아니라 진피의 회복 환경을 정돈합니다. 새살침은 표피를 통과해 진피층(<strong>0.4 – 2.0 mm</strong>)에 닿아 콜라겐 재구성을 유도합니다.</p>
    <div class="skin-cs-tags">
      <span class="skin-cs-tag">진피 0.8–1.5 mm</span>
      <span class="skin-cs-tag">TGF-β1 · MMP-1 · COL1A1 · CTGF</span>
      <span class="skin-cs-tag">in silico mapping</span>
    </div>
  </div>
  <div class="skin-cs-stage">
    <svg class="skin-cs-svg" viewBox="0 0 880 560" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="피부 단면 도식">
      <defs>
        <!-- Layer gradients -->
        <linearGradient id="epiGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#FBFAF6"/>
          <stop offset="100%" stop-color="#F1EDE3"/>
        </linearGradient>
        <linearGradient id="dermGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#F7F2E5" stop-opacity=".6"/>
          <stop offset="50%" stop-color="#FBF8F1"/>
          <stop offset="100%" stop-color="#F1EDE3"/>
        </linearGradient>
        <linearGradient id="subcutGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#F1EDE3"/>
          <stop offset="100%" stop-color="#E8E0CE"/>
        </linearGradient>
        <linearGradient id="muscleGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#E0D6BD"/>
          <stop offset="100%" stop-color="#D4C9AC"/>
        </linearGradient>

        <!-- Patterns -->
        <pattern id="hatchEpi" patternUnits="userSpaceOnUse" width="9" height="9">
          <circle cx="4.5" cy="4.5" r=".7" fill="#3D3D3D" opacity=".42"/>
        </pattern>
        <pattern id="hatchDermis" patternUnits="userSpaceOnUse" width="6" height="6" patternTransform="rotate(35)">
          <line x1="0" y1="0" x2="0" y2="6" stroke="#A88B4A" stroke-width=".55" opacity=".42"/>
        </pattern>
        <pattern id="hatchSubcut" patternUnits="userSpaceOnUse" width="14" height="14">
          <circle cx="7" cy="7" r="3.5" fill="none" stroke="#C4A265" stroke-width=".6" opacity=".5"/>
          <circle cx="7" cy="7" r="1.4" fill="#C4A265" opacity=".22"/>
        </pattern>
        <pattern id="hatchMuscle" patternUnits="userSpaceOnUse" width="12" height="3">
          <line x1="0" y1="1.5" x2="12" y2="1.5" stroke="#A88B4A" stroke-width=".5" opacity=".6"/>
        </pattern>

        <!-- Action zone glow -->
        <radialGradient id="needleGlow" cx=".5" cy=".5" r=".5">
          <stop offset="0%" stop-color="#C4A265" stop-opacity=".75"/>
          <stop offset="40%" stop-color="#C4A265" stop-opacity=".22"/>
          <stop offset="100%" stop-color="#C4A265" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="dermisGlow" cx=".5" cy=".5" r=".7">
          <stop offset="0%" stop-color="#A8C5A0" stop-opacity=".18"/>
          <stop offset="100%" stop-color="#A8C5A0" stop-opacity="0"/>
        </radialGradient>

        <!-- Drop shadow filter -->
        <filter id="softShadow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur in="SourceAlpha" stdDeviation="3"/>
          <feOffset dx="0" dy="2" result="offsetblur"/>
          <feComponentTransfer><feFuncA type="linear" slope=".25"/></feComponentTransfer>
          <feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>

      <!-- Background paper -->
      <rect x="0" y="0" width="880" height="560" fill="#FBFAF6"/>

      <!-- Outer skin contour line -->
      <path d="M40 64 Q200 56 440 60 T840 64" stroke="#1A1A1A" stroke-width="1.6" fill="none"/>

      <!-- ━━━ LAYER 1: Epidermis ━━━ -->
      <path d="M40 64 Q200 56 440 60 T840 64 L840 128 L40 128 Z" fill="url(#epiGrad)" stroke="#A88B4A" stroke-width=".5" opacity=".95"/>
      <path d="M40 64 Q200 56 440 60 T840 64 L840 128 L40 128 Z" fill="url(#hatchEpi)" opacity=".55"/>
      <text x="64" y="98" font-family="Noto Serif KR" font-size="13" fill="#1A1A1A" font-weight="500">표피 · Epidermis</text>
      <text x="64" y="116" font-family="IBM Plex Mono" font-size="9.5" fill="#5A5A5A" letter-spacing=".06em">0.05 – 0.15 mm</text>

      <!-- ━━━ LAYER 2: Dermis (회복 핵심층) — 강조 ━━━ -->
      <rect x="40" y="128" width="800" height="200" fill="url(#dermGrad)" stroke="#A88B4A" stroke-width=".5"/>
      <rect x="40" y="128" width="800" height="200" fill="url(#hatchDermis)"/>
      <!-- Glow halo across full dermis -->
      <ellipse cx="440" cy="228" rx="380" ry="80" fill="url(#dermisGlow)"/>

      <!-- Layer label with emphasis -->
      <rect x="48" y="142" width="184" height="44" fill="white" stroke="#2D5F3E" stroke-width="1" filter="url(#softShadow)"/>
      <text x="60" y="162" font-family="Noto Serif KR" font-size="15" fill="#2D5F3E" font-weight="500" font-style="italic">진피 · Dermis</text>
      <text x="60" y="178" font-family="IBM Plex Mono" font-size="9.5" fill="#5A5A5A" letter-spacing=".06em">0.4 – 2.0 mm · 회복의 무대</text>

      <!-- Collagen fiber network — much richer -->
      <g stroke="#2D5F3E" stroke-width=".75" fill="none" opacity=".62">
        <path d="M280 200 Q320 192 360 200 T440 200 T520 200 T600 200"/>
        <path d="M260 220 Q310 212 360 220 T440 220 T520 220 T600 220"/>
        <path d="M280 240 Q320 232 360 240 T440 240 T520 240 T600 240"/>
        <path d="M260 260 Q310 252 360 260 T440 260 T520 260 T600 260"/>
        <path d="M280 280 Q320 272 360 280 T440 280 T520 280 T600 280"/>
        <path d="M260 300 Q310 292 360 300 T440 300 T520 300 T600 300"/>
      </g>
      <line x1="612" y1="240" x2="676" y2="218" stroke="#2D5F3E" stroke-width=".55"/>
      <rect x="676" y="200" width="124" height="36" fill="white" stroke="#2D5F3E" stroke-width=".55"/>
      <text x="688" y="216" font-family="Noto Serif KR" font-size="11" fill="#2D5F3E" font-weight="500" font-style="italic">콜라겐 망</text>
      <text x="688" y="230" font-family="IBM Plex Mono" font-size="8.5" fill="#5A5A5A" letter-spacing=".04em">COL1A1 · 평행 재배열</text>

      <!-- Capillary dots (more, scattered) -->
      <g fill="#C4A265">
        <circle cx="120" cy="180" r="2.6"/>
        <circle cx="148" cy="206" r="2.6"/>
        <circle cx="170" cy="232" r="2.6"/>
        <circle cx="200" cy="266" r="2.6"/>
        <circle cx="220" cy="296" r="2.6"/>
        <circle cx="700" cy="200" r="2.6"/>
        <circle cx="720" cy="232" r="2.6"/>
        <circle cx="750" cy="262" r="2.6"/>
        <circle cx="780" cy="290" r="2.6"/>
        <circle cx="800" cy="260" r="2.6"/>
      </g>
      <line x1="180" y1="232" x2="116" y2="296" stroke="#A88B4A" stroke-width=".5"/>
      <text x="80" y="306" font-family="Noto Serif KR" font-size="10" fill="#A88B4A" font-style="italic">미세 혈관망</text>

      <!-- Molecular target nodes (TGF-β1 / MMP-1 / CTGF / COL1A1) — visual nodes instead of plain text -->
      <g>
        <!-- TGF-β1 -->
        <circle cx="320" cy="200" r="11" fill="white" stroke="#2D5F3E" stroke-width="1"/>
        <text x="320" y="203" text-anchor="middle" font-family="IBM Plex Mono" font-size="7" font-weight="500" fill="#2D5F3E" letter-spacing=".04em">TGF-β1</text>
        <!-- MMP-1 -->
        <circle cx="380" cy="240" r="11" fill="white" stroke="#2D5F3E" stroke-width="1"/>
        <text x="380" y="243" text-anchor="middle" font-family="IBM Plex Mono" font-size="7" font-weight="500" fill="#2D5F3E" letter-spacing=".04em">MMP-1</text>
        <!-- CTGF -->
        <circle cx="500" cy="240" r="11" fill="white" stroke="#2D5F3E" stroke-width="1"/>
        <text x="500" y="243" text-anchor="middle" font-family="IBM Plex Mono" font-size="7" font-weight="500" fill="#2D5F3E" letter-spacing=".04em">CTGF</text>
        <!-- COL1A1 -->
        <circle cx="560" cy="200" r="11" fill="white" stroke="#2D5F3E" stroke-width="1"/>
        <text x="560" y="203" text-anchor="middle" font-family="IBM Plex Mono" font-size="7" font-weight="500" fill="#2D5F3E" letter-spacing=".04em">COL1A1</text>
        <!-- LOX (extra) -->
        <circle cx="440" cy="172" r="9" fill="white" stroke="#2D5F3E" stroke-width=".8"/>
        <text x="440" y="175" text-anchor="middle" font-family="IBM Plex Mono" font-size="6.5" font-weight="500" fill="#2D5F3E" letter-spacing=".04em">LOX</text>
        <!-- connecting lines among targets -->
        <g stroke="#2D5F3E" stroke-width=".4" stroke-dasharray="2 2" opacity=".42" fill="none">
          <line x1="328" y1="207" x2="372" y2="237"/>
          <line x1="389" y1="240" x2="491" y2="240"/>
          <line x1="508" y1="237" x2="552" y2="207"/>
          <line x1="320" y1="190" x2="431" y2="172"/>
          <line x1="448" y1="172" x2="560" y2="190"/>
        </g>
      </g>

      <!-- ━━━ LAYER 3: Subcutis ━━━ -->
      <rect x="40" y="328" width="800" height="100" fill="url(#subcutGrad)" stroke="#A88B4A" stroke-width=".5"/>
      <rect x="40" y="328" width="800" height="100" fill="url(#hatchSubcut)"/>
      <text x="64" y="362" font-family="Noto Serif KR" font-size="13" fill="#1A1A1A" font-weight="500">피하 · Subcutis</text>
      <text x="64" y="380" font-family="IBM Plex Mono" font-size="9.5" fill="#5A5A5A" letter-spacing=".06em">2.0 – 8.0 mm · 지방·결합조직</text>

      <!-- ━━━ LAYER 4: Muscle / SMAS ━━━ -->
      <rect x="40" y="428" width="800" height="100" fill="url(#muscleGrad)" stroke="#A88B4A" stroke-width=".5"/>
      <rect x="40" y="428" width="800" height="100" fill="url(#hatchMuscle)"/>
      <text x="64" y="462" font-family="Noto Serif KR" font-size="13" fill="#1A1A1A" font-weight="500" font-style="italic">근막 · SMAS / Muscle</text>
      <text x="64" y="480" font-family="IBM Plex Mono" font-size="9.5" fill="#5A5A5A" letter-spacing=".06em">8 mm 이상 · 리프팅 지지점</text>

      <!-- ━━━ Needle insertion at center ━━━ -->
      <g transform="translate(440 0)">
        <!-- Glow halo -->
        <ellipse cx="0" cy="240" rx="86" ry="56" fill="url(#needleGlow)"/>
        <ellipse cx="0" cy="240" rx="64" ry="44" fill="url(#needleGlow)" opacity=".55"/>
        <!-- Needle handle (gold) -->
        <rect x="-8" y="-8" width="16" height="28" fill="#A88B4A" stroke="#1A1A1A" stroke-width=".7"/>
        <rect x="-7" y="-6" width="14" height="2" fill="#C4A265"/>
        <rect x="-7" y="0" width="14" height="2" fill="#C4A265"/>
        <!-- Needle shaft -->
        <line x1="0" y1="20" x2="0" y2="252" stroke="#1A1A1A" stroke-width="1.6" stroke-linecap="round"/>
        <!-- Needle taper near tip -->
        <line x1="-1.2" y1="240" x2="0" y2="262" stroke="#1A1A1A" stroke-width="1.6"/>
        <line x1="1.2" y1="240" x2="0" y2="262" stroke="#1A1A1A" stroke-width="1.6"/>
        <!-- Action target rings -->
        <circle cx="0" cy="252" r="9" fill="none" stroke="#2D5F3E" stroke-width="1.6"/>
        <circle cx="0" cy="252" r="18" fill="none" stroke="#2D5F3E" stroke-width=".7" stroke-dasharray="2 2" opacity=".7"/>
        <circle cx="0" cy="252" r="28" fill="none" stroke="#2D5F3E" stroke-width=".5" stroke-dasharray="2 3" opacity=".5"/>
      </g>

      <!-- Needle label -->
      <line x1="450" y1="14" x2="600" y2="14" stroke="#1A1A1A" stroke-width=".6"/>
      <rect x="606" y="-2" width="180" height="32" fill="white" stroke="#1A1A1A" stroke-width=".6" filter="url(#softShadow)"/>
      <text x="616" y="14" font-family="Noto Serif KR" font-size="12" fill="#1A1A1A" font-weight="500">새살침 · Saessal Needle</text>
      <text x="616" y="26" font-family="IBM Plex Mono" font-size="9" fill="#5A5A5A" letter-spacing=".06em">목표 깊이 0.8 – 1.5 mm</text>

      <!-- Depth scale (right) -->
      <g transform="translate(852 0)" font-family="IBM Plex Mono" font-size="8.5" fill="#5A5A5A" letter-spacing=".04em">
        <line x1="0" y1="64" x2="0" y2="528" stroke="#A88B4A" stroke-width=".7"/>
        <line x1="-3" y1="64" x2="3" y2="64" stroke="#A88B4A" stroke-width=".6"/>
        <line x1="-3" y1="128" x2="3" y2="128" stroke="#A88B4A" stroke-width=".6"/>
        <line x1="-3" y1="252" x2="3" y2="252" stroke="#C4A265" stroke-width="1.4"/>
        <line x1="-3" y1="328" x2="3" y2="328" stroke="#A88B4A" stroke-width=".6"/>
        <line x1="-3" y1="428" x2="3" y2="428" stroke="#A88B4A" stroke-width=".6"/>
        <line x1="-3" y1="528" x2="3" y2="528" stroke="#A88B4A" stroke-width=".6"/>
        <text x="6" y="68">0 mm</text>
        <text x="6" y="132">0.1</text>
        <text x="6" y="256" fill="#A88B4A" font-weight="500">1.0 ←</text>
        <text x="6" y="332">2.0</text>
        <text x="6" y="432">8.0</text>
        <text x="6" y="532">10+</text>
      </g>

      <!-- Bottom caption -->
      <text x="440" y="552" text-anchor="middle" font-family="IBM Plex Mono" font-size="9" fill="#5A5A5A" letter-spacing=".22em">FIG. 1 · 4-LAYER SKIN CROSS-SECTION · IN SILICO MAPPING</text>
    </svg>
  </div>
</figure>

<style>
.skin-cs{margin:48px 0;padding:36px clamp(20px,4vw,48px);background:white;border:1px solid rgba(26,26,26,.16);position:relative;box-shadow:0 1px 0 rgba(196,162,101,.16),0 16px 48px rgba(45,95,62,.05)}
.skin-cs::before{content:'';position:absolute;top:0;left:0;width:120px;height:2px;background:#A88B4A}
.skin-cs-cap{margin-bottom:28px;max-width:760px}
.skin-cs-eye{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.32em;color:#A88B4A;text-transform:uppercase;font-weight:500;display:inline-block;margin-bottom:12px}
.skin-cs-title{font-family:'Fraunces','Noto Serif KR',Georgia,serif;font-size:clamp(22px,3vw,32px);font-weight:300;color:#1A1A1A;line-height:1.22;letter-spacing:-.012em;margin-bottom:12px}
.skin-cs-title em{font-style:italic;color:#2D5F3E;font-weight:500}
.skin-cs-sub{font-family:'Noto Serif KR',Georgia,serif;font-size:14.5px;line-height:1.78;color:#3D3D3D;font-weight:300;margin-bottom:14px}
.skin-cs-sub strong{color:#2D5F3E;font-weight:500}
.skin-cs-tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px}
.skin-cs-tag{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.14em;color:#2D5F3E;background:rgba(45,95,62,.06);padding:5px 11px;border:1px solid rgba(45,95,62,.2);text-transform:uppercase;font-weight:500}
.skin-cs-stage{position:relative;background:linear-gradient(180deg,#FBFAF6 0%,#F4F0E5 100%);padding:18px;border:1px solid rgba(196,162,101,.22);box-shadow:0 1px 0 rgba(255,255,255,.8) inset,0 8px 24px rgba(45,95,62,.05)}
.skin-cs-stage::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(196,162,101,.05) 0%,transparent 60%);pointer-events:none}
.skin-cs-svg{width:100%;height:auto;display:block;max-width:960px;margin:0 auto;position:relative;z-index:1}
@media(max-width:560px){
  .skin-cs{padding:24px 16px}
  .skin-cs-stage{padding:8px}
}
</style>
