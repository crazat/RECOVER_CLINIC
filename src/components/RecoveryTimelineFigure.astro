---
// RecoveryTimelineFigure — Day 0/7/30/90/180 시점별 피부 단면 미니 일러스트
// 각 시점에 함몰/처짐/주름 시각화 + 회복되면서 평탄해지는 과정
const phases = [
  { day: 'Day 0', label: '시술 직후', desc: '깊은 함몰 + 강한 홍조 + 미세 손상', state: 'red' },
  { day: 'Day 7', label: '초기 회복', desc: '딱지·붉기 정리 · 함몰 잔존', state: 'pink' },
  { day: 'Day 30', label: '중기 회복', desc: '콜라겐 재구성 시작 · 함몰 축소', state: 'green' },
  { day: 'Day 90', label: '구조 회복', desc: '표면 함몰 단계적 평탄화', state: 'green2' },
  { day: 'Day 180', label: '회복 안정기', desc: '재구성 완료 · 다음 회복 기준 정리', state: 'final' },
];
---
<figure class="rec-tl" aria-label="회복 타임라인 시점별 피부 단면 시각화">
  <div class="rec-tl-cap">
    <span class="rec-tl-eye">Recovery Timeline · 0–180 days</span>
    <h3 class="rec-tl-title">회복은 한 번의 사건이 아니라<br/><em>다섯 단계</em>의 흐름입니다</h3>
    <p class="rec-tl-sub">Day 0의 깊은 함몰과 강한 홍조에서 Day 180의 평탄·안정까지, 각 시점에서 일어나는 진피 안 변화를 단면으로 시각화했습니다. 표면이 차오르는 것이 아니라 <strong>구조가 재구성</strong>되는 과정입니다.</p>
  </div>

  <div class="rec-tl-rail">
    <div class="rec-tl-line"></div>
    <div class="rec-tl-grid">
      {phases.map((p) => (
        <div class={`rec-tl-node rec-tl-node--${p.state}`}>
          <svg class="rec-tl-svg" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" role="img">
            <defs>
              <linearGradient id={`tl-skin-${p.state}`} x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#FBFAF6"/>
                <stop offset="100%" stop-color="#F1EDE3"/>
              </linearGradient>
              <linearGradient id={`tl-dep-${p.state}`} x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#3D3D3D" stop-opacity="0"/>
                <stop offset="100%" stop-color="#1A1A1A" stop-opacity=".55"/>
              </linearGradient>
              <pattern id={`tl-derm-${p.state}`} patternUnits="userSpaceOnUse" width="4" height="4" patternTransform="rotate(35)">
                <line x1="0" y1="0" x2="0" y2="4" stroke="#A88B4A" stroke-width=".4" opacity=".42"/>
              </pattern>
            </defs>

            {/* Day 0: deep V-notch + red flare + rough surface */}
            {p.state === 'red' && (
              <g>
                <path d="M5 30 L24 30 L36 70 L48 30 L72 30 Q88 30 95 30" fill={`url(#tl-skin-${p.state})`} stroke="#1A1A1A" stroke-width=".9" stroke-linejoin="round"/>
                <path d="M5 30 L24 30 L36 70 L48 30 L72 30 Q88 30 95 30 L95 95 L5 95 Z" fill={`url(#tl-skin-${p.state})`} stroke="#1A1A1A" stroke-width=".9"/>
                <path d="M24 30 L36 70 L48 30 Z" fill={`url(#tl-dep-${p.state})`} opacity=".82"/>
                <rect x="5" y="40" width="90" height="55" fill={`url(#tl-derm-${p.state})`}/>
                <ellipse cx="36" cy="52" rx="22" ry="10" fill="#d94a4a" opacity=".55"/>
                <ellipse cx="36" cy="52" rx="14" ry="6" fill="#a82828" opacity=".4"/>
                {/* surface microtrauma dots */}
                <g fill="#7a3a3a">
                  <circle cx="14" cy="29" r=".7"/>
                  <circle cx="20" cy="29" r=".7"/>
                  <circle cx="56" cy="29" r=".7"/>
                  <circle cx="64" cy="29" r=".7"/>
                  <circle cx="78" cy="29" r=".7"/>
                </g>
                {/* tension arrows pulling inward */}
                <g stroke="#7a3a3a" stroke-width=".7" fill="#7a3a3a" opacity=".6">
                  <line x1="22" y1="58" x2="14" y2="58" stroke-dasharray="1.5 1"/>
                  <polygon points="16,56 12,58 16,60"/>
                  <line x1="50" y1="58" x2="58" y2="58" stroke-dasharray="1.5 1"/>
                  <polygon points="56,56 60,58 56,60"/>
                </g>
              </g>
            )}

            {/* Day 7: shallower depression + pink tone + scab traces */}
            {p.state === 'pink' && (
              <g>
                <path d="M5 30 L26 30 Q30 30 32 36 L36 56 Q36 60 38 56 L42 36 Q44 30 48 30 L95 30 L95 95 L5 95 Z" fill={`url(#tl-skin-${p.state})`} stroke="#1A1A1A" stroke-width=".9" stroke-linejoin="round"/>
                <path d="M26 30 Q30 30 32 36 L36 56 Q36 60 38 56 L42 36 Q44 30 48 30 Z" fill={`url(#tl-dep-${p.state})`} opacity=".55"/>
                <rect x="5" y="40" width="90" height="55" fill={`url(#tl-derm-${p.state})`}/>
                <ellipse cx="37" cy="50" rx="18" ry="7" fill="#e88d8d" opacity=".42"/>
                {/* scab dots */}
                <g fill="#a85a4a">
                  <circle cx="32" cy="34" r="1"/>
                  <circle cx="38" cy="33" r="1"/>
                  <circle cx="42" cy="34" r="1"/>
                </g>
              </g>
            )}

            {/* Day 30: small dimple + collagen waves emerging + gold needle marks */}
            {p.state === 'green' && (
              <g>
                <path d="M5 30 L30 30 Q35 30 38 33 L40 42 Q40 45 42 42 L44 33 Q46 30 50 30 L95 30 L95 95 L5 95 Z" fill={`url(#tl-skin-${p.state})`} stroke="#1A1A1A" stroke-width=".9" stroke-linejoin="round"/>
                <path d="M30 30 Q35 30 38 33 L40 42 Q40 45 42 42 L44 33 Q46 30 50 30 Z" fill={`url(#tl-dep-${p.state})`} opacity=".34"/>
                <rect x="5" y="40" width="90" height="55" fill={`url(#tl-derm-${p.state})`}/>
                <ellipse cx="40" cy="52" rx="20" ry="10" fill="#A8C5A0" opacity=".22"/>
                <g stroke="#2D5F3E" stroke-width=".6" fill="none" opacity=".75">
                  <path d="M16 56 Q30 53 40 56 T76 56"/>
                  <path d="M16 66 Q30 63 40 66 T76 66"/>
                  <path d="M16 76 Q30 73 40 76 T76 76"/>
                </g>
                <g fill="#C4A265">
                  <circle cx="32" cy="34" r="1.2"/>
                  <circle cx="40" cy="33" r="1.2"/>
                  <circle cx="48" cy="34" r="1.2"/>
                </g>
              </g>
            )}

            {/* Day 90: nearly flat + rich collagen network */}
            {p.state === 'green2' && (
              <g>
                <path d="M5 30 L34 30 Q38 30 40 32 Q42 34 44 32 Q46 30 50 30 L95 30 L95 95 L5 95 Z" fill={`url(#tl-skin-${p.state})`} stroke="#1A1A1A" stroke-width=".9" stroke-linejoin="round"/>
                <rect x="5" y="40" width="90" height="55" fill={`url(#tl-derm-${p.state})`}/>
                <ellipse cx="40" cy="55" rx="26" ry="14" fill="#A8C5A0" opacity=".32"/>
                <g stroke="#2D5F3E" stroke-width=".7" fill="none" opacity=".88">
                  <path d="M14 50 Q30 48 40 50 T76 50"/>
                  <path d="M14 60 Q30 58 40 60 T76 60"/>
                  <path d="M14 70 Q30 68 40 70 T76 70"/>
                  <path d="M14 80 Q30 78 40 80 T76 80"/>
                </g>
                {/* fading needle marks */}
                <g fill="#C4A265" opacity=".5">
                  <circle cx="34" cy="34" r="1"/>
                  <circle cx="42" cy="34" r="1"/>
                  <circle cx="48" cy="34" r="1"/>
                </g>
              </g>
            )}

            {/* Day 180: completely flat + stable collagen + gold seal */}
            {p.state === 'final' && (
              <g>
                <path d="M5 30 L95 30 L95 95 L5 95 Z" fill={`url(#tl-skin-${p.state})`} stroke="#1A1A1A" stroke-width=".9"/>
                <rect x="5" y="40" width="90" height="55" fill={`url(#tl-derm-${p.state})`}/>
                <g stroke="#2D5F3E" stroke-width=".7" fill="none" opacity=".88">
                  <path d="M14 48 Q30 47 40 48 T76 48"/>
                  <path d="M14 58 Q30 57 40 58 T76 58"/>
                  <path d="M14 68 Q30 67 40 68 T76 68"/>
                  <path d="M14 78 Q30 77 40 78 T76 78"/>
                </g>
                {/* gold ornament — recovery seal */}
                <circle cx="50" cy="22" r="3.2" fill="#C4A265" opacity=".88"/>
                <circle cx="50" cy="22" r="6" fill="none" stroke="#A88B4A" stroke-width=".5" stroke-dasharray="1.5 1.5" opacity=".7"/>
                <circle cx="50" cy="22" r="9" fill="none" stroke="#A88B4A" stroke-width=".3" stroke-dasharray="1 1.5" opacity=".4"/>
              </g>
            )}
          </svg>
          <span class="rec-tl-dot"></span>
          <p class="rec-tl-day">{p.day}</p>
          <p class="rec-tl-label">{p.label}</p>
          <p class="rec-tl-desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <p class="rec-tl-foot">FIG. 4 · Recovery Timeline · 진피 단면 · 0 → 180 days · in-clinic 평균 관찰 (개인차 있음)</p>
</figure>

<style>
.rec-tl{margin:48px 0;padding:40px clamp(20px,4vw,56px);background:white;border:1px solid rgba(26,26,26,.16);position:relative;box-shadow:0 1px 0 rgba(196,162,101,.16),0 16px 48px rgba(45,95,62,.05)}
.rec-tl::before{content:'';position:absolute;top:0;left:0;width:120px;height:2px;background:#A88B4A}
.rec-tl-cap{margin-bottom:32px;max-width:760px}
.rec-tl-eye{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.32em;color:#A88B4A;text-transform:uppercase;font-weight:500;display:inline-block;margin-bottom:12px}
.rec-tl-title{font-family:'Fraunces','Noto Serif KR',Georgia,serif;font-size:clamp(22px,3vw,30px);font-weight:300;color:#1A1A1A;line-height:1.28;letter-spacing:-.008em;margin-bottom:10px}
.rec-tl-title em{font-style:italic;color:#2D5F3E;font-weight:500}
.rec-tl-sub{font-family:'Noto Serif KR',Georgia,serif;font-size:14.5px;line-height:1.78;color:#3D3D3D;font-weight:300}
.rec-tl-sub strong{color:#7a3a3a;font-weight:500}
.rec-tl-rail{position:relative;margin-top:36px}
.rec-tl-line{position:absolute;top:90px;left:5%;right:5%;height:2px;background:linear-gradient(to right,#7a3a3a 0%,#e88d8d 22%,#A88B4A 50%,#4A8C5E 78%,#2D5F3E 100%);opacity:.5}
.rec-tl-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:18px;position:relative}
.rec-tl-node{display:flex;flex-direction:column;align-items:center;text-align:center;position:relative}
.rec-tl-svg{width:100px;height:100px;border:1px solid rgba(196,162,101,.22);background:#FBFAF6;padding:0;display:block;box-shadow:0 1px 0 rgba(196,162,101,.16) inset,0 6px 18px rgba(45,95,62,.04)}
.rec-tl-dot{width:14px;height:14px;border-radius:50%;background:white;border:2px solid #A88B4A;margin-top:0;position:relative;z-index:2;display:block}
.rec-tl-node--red .rec-tl-dot{background:#d94a4a;border-color:#7a3a3a;box-shadow:0 0 0 4px rgba(217,74,74,.16)}
.rec-tl-node--pink .rec-tl-dot{background:#e88d8d;border-color:#A88B4A}
.rec-tl-node--green .rec-tl-dot{background:#A8C5A0;border-color:#2D5F3E}
.rec-tl-node--green2 .rec-tl-dot{background:#4A8C5E;border-color:#2D5F3E}
.rec-tl-node--final .rec-tl-dot{background:#C4A265;border-color:#A88B4A;box-shadow:0 0 0 4px rgba(196,162,101,.22)}
.rec-tl-day{font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.18em;color:#A88B4A;text-transform:uppercase;font-weight:500;margin-top:14px}
.rec-tl-label{font-family:'Fraunces','Noto Serif KR',serif;font-size:14.5px;font-weight:500;color:#1A1A1A;margin-top:2px;line-height:1.32}
.rec-tl-desc{font-family:'Noto Serif KR',serif;font-size:11.5px;line-height:1.6;color:#5A5A5A;font-weight:300;margin-top:6px;max-width:160px}
.rec-tl-foot{margin-top:36px;font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.18em;color:#5A5A5A;text-transform:uppercase;text-align:center;padding-top:18px;border-top:1px solid rgba(196,162,101,.16)}
@media(max-width:768px){
  .rec-tl-grid{grid-template-columns:1fr 1fr;gap:24px}
  .rec-tl-line{display:none}
}
@media(max-width:480px){.rec-tl-grid{grid-template-columns:1fr}}
</style>
