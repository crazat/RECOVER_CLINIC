<script is:inline>
(function(){
  const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{
    "variant": "heritage",
    "radius": "soft",
    "density": "compact"
  }/*EDITMODE-END*/;

  const state = Object.assign({}, TWEAK_DEFAULTS);
  const html = document.documentElement;

  function apply(){
    if(state.variant && state.variant !== 'heritage') html.setAttribute('data-variant', state.variant);
    else html.removeAttribute('data-variant');
    html.setAttribute('data-radius', state.radius || 'sharp');
    html.setAttribute('data-density', state.density || 'comfy');
    // Update active buttons
    document.querySelectorAll('#tweaksVariants .tweaks-variant').forEach(b=>{
      b.classList.toggle('active', b.dataset.variant === state.variant);
    });
    document.querySelectorAll('#tweaksRadius .tweaks-variant').forEach(b=>{
      b.classList.toggle('active', b.dataset.radius === state.radius);
    });
    document.querySelectorAll('#tweaksDensity .tweaks-variant').forEach(b=>{
      b.classList.toggle('active', b.dataset.density === state.density);
    });
  }

  function persist(edits){
    Object.assign(state, edits);
    try{ window.parent.postMessage({type:'__edit_mode_set_keys', edits:state}, '*'); }catch(e){}
    apply();
  }

  // Wire up buttons
  document.querySelectorAll('#tweaksVariants .tweaks-variant').forEach(b=>{
    b.addEventListener('click', ()=>persist({variant: b.dataset.variant}));
  });
  document.querySelectorAll('#tweaksRadius .tweaks-variant').forEach(b=>{
    b.addEventListener('click', ()=>persist({radius: b.dataset.radius}));
  });
  document.querySelectorAll('#tweaksDensity .tweaks-variant').forEach(b=>{
    b.addEventListener('click', ()=>persist({density: b.dataset.density}));
  });

  apply();

  // Edit mode protocol
  const panel = document.getElementById('tweaksPanel');
  const closeBtn = document.getElementById('tweaksClose');
  closeBtn.addEventListener('click', ()=>{
    panel.classList.remove('open');
    try{ window.parent.postMessage({type:'__edit_mode_deactivated'}, '*'); }catch(e){}
  });

  window.addEventListener('message', (e)=>{
    const d = e.data || {};
    if(d.type === '__activate_edit_mode'){ panel.classList.add('open'); panel.setAttribute('aria-hidden','false'); }
    else if(d.type === '__deactivate_edit_mode'){ panel.classList.remove('open'); panel.setAttribute('aria-hidden','true'); }
  });

  try{ window.parent.postMessage({type:'__edit_mode_available'}, '*'); }catch(e){}
})();
</script>

