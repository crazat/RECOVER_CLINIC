<!-- ═══ SIGNATURE UPGRADES — cursor / nav / chapters / quiet mode ═══ -->
<script is:inline>
(function(){
  const prefersReduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const hoverable = matchMedia('(hover: hover)').matches;
  const doc = document.documentElement;

  /* ─── B11: Gold ink-drop cursor ─── */
  if(hoverable && !prefersReduce && !('ontouchstart' in window)){
    let lastT = 0;
    document.addEventListener('mousemove', (e)=>{
      const now = performance.now();
      if(now - lastT < 60) return;
      lastT = now;
      if(doc.getAttribute('data-quiet') === 'on') return;
      const d = document.createElement('span');
      d.className = 'ink-drop';
      d.style.left = e.clientX + 'px';
      d.style.top = e.clientY + 'px';
      d.style.setProperty('--s', (.7 + Math.random()*.5).toFixed(2));
      document.body.appendChild(d);
      setTimeout(()=>d.remove(), 950);
    }, {passive:true});
  }

  /* ─── B14: Nav hide-until-scroll (past hero) ─── */
  const navEl = document.getElementById('nav');
  let lastY = 0;
  function updateNavMode(){
    const y = window.scrollY;
    const heroH = window.innerHeight * .85;
    if(y < heroH){
      doc.setAttribute('data-nav-mode', 'hidden-hero');
    } else {
      // Show when scrolled past hero, hide when scrolling down fast past a threshold
      if(y > lastY + 6 && y > heroH + 200){
        doc.setAttribute('data-nav-mode', 'hidden-hero');
      } else if(y < lastY - 4 || y < heroH + 200){
        doc.setAttribute('data-nav-mode', 'visible');
      }
    }
    lastY = y;
  }
  updateNavMode();
  window.addEventListener('scroll', updateNavMode, {passive:true});

  /* ─── B12: Chapter rail ─── */
  const rail = document.getElementById('chapterRail');
  const pips = rail ? [...rail.querySelectorAll('.chapter-pip')] : [];
  const sections = pips.map(p => document.getElementById(p.dataset.chapter)).filter(Boolean);
  function updateChapters(){
    const y = window.scrollY + window.innerHeight * .35;
    let active = -1;
    sections.forEach((s, i)=>{
      const top = s.getBoundingClientRect().top + window.scrollY;
      if(y >= top) active = i;
    });
    pips.forEach((p, i)=>p.classList.toggle('active', i === active));
    // Show rail once we've passed the hero
    if(rail) rail.classList.toggle('show', window.scrollY > window.innerHeight * .7);
  }
  if(rail){
    updateChapters();
    window.addEventListener('scroll', updateChapters, {passive:true});
  }

  /* ─── B13: Quiet mode toggle ─── */
  const qtBtn = document.getElementById('quietToggle');
  try{
    if(localStorage.getItem('recover-quiet') === 'on'){
      doc.setAttribute('data-quiet', 'on');
    }
  }catch(e){}
  if(qtBtn){
    qtBtn.addEventListener('click', ()=>{
      const on = doc.getAttribute('data-quiet') === 'on';
      if(on){
        doc.removeAttribute('data-quiet');
        try{ localStorage.setItem('recover-quiet', 'off'); }catch(e){}
      } else {
        doc.setAttribute('data-quiet', 'on');
        try{ localStorage.setItem('recover-quiet', 'on'); }catch(e){}
      }
    });
  }

  /* ─── A8: Ink bloom reveal ─── */
  const blooms = document.querySelectorAll('.ink-bloom');
  if(blooms.length && 'IntersectionObserver' in window){
    const io = new IntersectionObserver(es=>{
      es.forEach(e=>{
        if(e.isIntersecting){ e.target.classList.add('rv-in'); io.unobserve(e.target); }
      });
    }, {threshold:.3});
    blooms.forEach(b=>io.observe(b));
  }

  /* ─── UP-5: Seasonal auto-switch ─── */
  const m = new Date().getMonth(); // 0=Jan
  const season = m>=2 && m<=4 ? 'spring' : m>=5 && m<=7 ? 'summer' : m>=8 && m<=10 ? 'autumn' : 'winter';
  doc.setAttribute('data-season', season);
  // Update the season badge if present
  const sb = document.getElementById('seasonBadge');
  if(sb){
    const labels = {
      spring: {ko:'봄', en:'Spring', emoji:'❀'},
      summer: {ko:'여름', en:'Summer', emoji:'☀'},
      autumn: {ko:'가을', en:'Autumn', emoji:'❧'},
      winter: {ko:'겨울', en:'Winter', emoji:'❄'}
    };
    const l = labels[season];
    sb.querySelector('.sb-ko').textContent = l.ko;
    sb.querySelector('.sb-en').textContent = l.en;
    sb.querySelector('.sb-gl').textContent = l.emoji;
  }
})();
</script>

