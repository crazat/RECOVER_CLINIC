  sheet.querySelector('.price-sheet-close').addEventListener('click',closePriceSheet);
  document.addEventListener('keydown',e=>{if(e.key==='Escape')closePriceSheet()});
  // Swipe-down to close
  const body=sheet.querySelector('.price-sheet-body');
  let sy=0,cy=0,dragging=false;
  body.addEventListener('touchstart',e=>{if(body.scrollTop>0)return;sy=e.touches[0].clientY;dragging=true},{passive:true});
  body.addEventListener('touchmove',e=>{
    if(!dragging)return;
    cy=e.touches[0].clientY;
    const d=cy-sy;
    if(d>0){body.style.transform=`translateY(${d}px)`;body.style.transition='none'}
  },{passive:true});
  body.addEventListener('touchend',()=>{
    if(!dragging)return;dragging=false;
    const d=cy-sy;
    body.style.transition='';
    if(d>100)closePriceSheet();
    body.style.transform='';
  });
})();

