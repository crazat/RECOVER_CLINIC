     clinical:'콜라겐 합성 신호 활성화 개시'},
    {day:'Day 7',label:'1주차',
     headline:'미세한 <em>변화</em>가 감지되기 시작',
     desc:'붓기와 자극감이 대부분 해소됩니다. 주변에서 먼저 알아보는 시기 — "뭔가 달라 보이네"라는 말을 듣기 시작합니다.',
     feel:'피부 결이 정돈, 탄력감 초기 회복',
     clinical:'신생 콜라겐 배열 형성 진행'},
    {day:'Day 30',label:'1개월',
     headline:'거울 앞에서 <em>느끼는</em> 변화',
     desc:'스스로도 명확히 체감하는 단계. 피부 톤이 고르게 정리되고 탄력이 뚜렷해집니다. 많은 분들이 이 시점에 추가 진료를 결심하십니다.',
     feel:'톤 정리, 리프팅 효과 가시화',
     clinical:'콜라겐 리모델링 본격 진입'},
    {day:'Day 90',label:'3개월',
     headline:'본래의 <em>피부 힘</em>이 되살아난 상태',
     desc:'시술 효과가 완전히 자리잡는 시기. 재생된 조직이 원래 피부의 일부가 되어 자연스러움이 극대화됩니다. 이 상태를 유지하는 관리 프로토콜을 안내드립니다.',
     feel:'안정된 탄력·톤, 자연스러운 완성',
     clinical:'재생 조직 구조 안정화 완료'}
  ];

  const pts=track.querySelectorAll('.tl-pt');
  const labels=track.querySelectorAll('.tl-label');
  const chips=document.querySelectorAll('.tl-chip');
  const stages=document.querySelectorAll('#tlStage svg');
  let cur=0;
  let auto=null;

  function setIdx(i,fromUser){
    cur=i;
    const pct=(i/(data.length-1))*100;
    fill.style.width=pct+'%';
    pts.forEach((p,idx)=>{
      p.classList.toggle('active',idx===i);
      p.classList.toggle('reached',idx<i);
    });
    labels.forEach((l,idx)=>l.classList.toggle('active',idx===i));
    chips.forEach((c,idx)=>{
      const on=idx===i;
      c.classList.toggle('active',on);
      c.setAttribute('aria-selected',on?'true':'false');
    });
    stages.forEach(s=>s.classList.toggle('active',+s.dataset.idx===i));

    const d=data[i];
    document.getElementById('tlMarker').textContent=d.day+' · '+d.label;
    document.getElementById('tlHeadline').innerHTML=d.headline;
    document.getElementById('tlDesc').textContent=d.desc;
    document.getElementById('tlFeel').textContent=d.feel;
    document.getElementById('tlClinical').textContent=d.clinical;

    // 사용자가 직접 선택하면 auto 중지
    if(fromUser&&auto){clearInterval(auto);auto=null;updatePlayBtn(false)}
  }

  pts.forEach(p=>p.addEventListener('click',()=>setIdx(+p.dataset.idx,true)));
  labels.forEach(l=>l.addEventListener('click',()=>setIdx(+l.dataset.idx,true)));
  chips.forEach(c=>c.addEventListener('click',()=>setIdx(+c.dataset.jump,true)));

  // 초기 상태 동기화 — 첫 칩 active 표시
  setIdx(0,false);

  const playBtn=document.getElementById('tlPlay');
  function updatePlayBtn(playing){
    playBtn.innerHTML=playing
      ?'<svg viewBox="0 0 10 10" fill="currentColor"><rect x="2" y="1" width="2" height="8"/><rect x="6" y="1" width="2" height="8"/></svg>'
      :'<svg viewBox="0 0 10 10" fill="currentColor"><path d="M2 1l7 4-7 4z"/></svg>';
  }
  function startAuto(){
    if(auto)return;
    updatePlayBtn(true);
    auto=setInterval(()=>{
      setIdx((cur+1)%data.length,false);
    },3200);
  }
  playBtn.addEventListener('click',()=>{
    if(auto){clearInterval(auto);auto=null;updatePlayBtn(false)}
    else startAuto();
  });

  // 스크롤로 섹션 진입 시 한 번 자동재생 시작
  const io=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting&&!auto&&cur===0){
        setTimeout(startAuto,800);
        io.disconnect();
      }
    });
  },{threshold:.4});
  io.observe(document.getElementById('timeline'));
})();

/* ═══ FOUNDER'S LETTER — expand/collapse ═══ */
(function(){
  const btn=document.getElementById('founderExpandBtn');
  const more=document.getElementById('founderMore');
  const sig=document.getElementById('founderSig');
  const fade=document.getElementById('founderFade');
  const wrap=document.getElementById('founderExpandWrap');
  if(!btn||!more||!sig||!fade||!wrap)return;
  btn.addEventListener('click',()=>{
    const open=btn.getAttribute('aria-expanded')==='true';
    if(open){
      // collapse
      more.hidden=true;
      sig.hidden=true;
      fade.classList.remove('hidden');
      wrap.classList.remove('expanded');
      btn.setAttribute('aria-expanded','false');
      btn.querySelector('.founder-expand-label').textContent='이야기 전체 읽기';
      // 부드럽게 섹션 상단으로
      document.getElementById('founder').scrollIntoView({behavior:'smooth',block:'start'});
    } else {
      // expand
      more.hidden=false;
      sig.hidden=false;
      fade.classList.add('hidden');
      wrap.classList.add('expanded');
      btn.setAttribute('aria-expanded','true');
      btn.querySelector('.founder-expand-label').textContent='이야기 전체 읽기';
    }
  });
})();

