/* ═══ STICKY CONTEXT CHIP — 스크롤 섹션 기반 프롬프트 ═══ */
(function(){
  const chip=document.getElementById('ctxChip');
  const chipText=document.getElementById('ctxChipText');
  const chipCta=document.getElementById('ctxChipCta');
  const chipClose=document.getElementById('ctxChipClose');
  if(!chip||!chipText)return;

  // 세션당 닫기 상태
  let dismissed=sessionStorage.getItem('ctxChipDismissed')==='1';

  // 다음 예약 가능 슬롯 계산 (일요일 제외, 평일 선호 오전 10:30)
  function nextSlot(){
    const now=new Date();
    const dayNames=['일','월','화','수','목','금','토'];
    // 시드 슬롯: 다음 영업일 오후 3시, 그 다음 오전 10:30
    const candidates=[
      {off:1,time:'오후 3:00'},
      {off:2,time:'오전 10:30'},
      {off:1,time:'오후 4:30'}
    ];
    // 오늘 이후 가장 빠른 영업일(일요일 제외)
    let chosen=candidates[0];
    for(const c of candidates){
      const d=new Date(now);d.setDate(now.getDate()+c.off);
      if(d.getDay()!==0){chosen=c;break}
    }
    const d=new Date(now);d.setDate(now.getDate()+chosen.off);
    const isToday=chosen.off===0;
    const isTmr=chosen.off===1;
    const label=isToday?'오늘':isTmr?'내일':(d.getMonth()+1)+'/'+d.getDate()+' ('+dayNames[d.getDay()]+')';
    return label+' '+chosen.time;
  }
  const slotText=nextSlot();

  // 모바일 바텀바 primary CTA의 슬롯도 같은 소스로 동기화
  const mbSlot=document.getElementById('mbSlot');
  if(mbSlot)mbSlot.textContent=slotText+' 가능';

  // 섹션별 메시지 맵 — 모두 "다음 슬롯" 기반 라이브 칩
  const ctxMap={
    'treatments':{label:'가장 빠른 상담',slot:slotText,cta:'이 시간 예약',href:'#consult'},
    'doctor':{label:'리커버 기준 상담',slot:slotText,cta:'바로 예약',href:'#consult'},
    'gallery':{label:'나도 이런 변화가 가능할까?',slot:slotText,cta:'기준 상담',href:'#consult'},
    'process':{label:'첫 단계는 상담부터',slot:slotText,cta:'지금 시작',href:'#consult'},
    'timeline':{label:'오늘 시작하면 D-14는',slot:slotText,cta:'상담 잡기',href:'#consult'},
    'precision':{label:'RECOVER BASELINE',slot:slotText,cta:'예약',href:'#consult'},
    'reviews':{label:'다음 상담 자리',slot:slotText,cta:'내 차례',href:'#consult'},
    'faq':{label:'카톡으로도 상담 가능',slot:'평일 9~18시',cta:'지금 문의',href:'https://pf.kakao.com/_DxewtT/chat'},
    'consult':{label:'이번 주 가능 자리',slot:slotText,cta:'예약 진행',href:'#consult'},
  };

  const sections=Object.keys(ctxMap).map(id=>({id,el:document.getElementById(id)})).filter(s=>s.el);
  if(!sections.length)return;

  let current=null;
  let scrollTimer=null;
  let firstShow=false;
  const chipSlot=document.getElementById('ctxChipSlot');

  function updateChip(){
    if(dismissed)return;
    // 어느 섹션이 가장 많이 화면에 보이는지
    const vh=window.innerHeight;
    let best=null,bestScore=-1;
    sections.forEach(s=>{
      const r=s.el.getBoundingClientRect();
      const top=Math.max(r.top,0);
      const bot=Math.min(r.bottom,vh);
      const visible=Math.max(0,bot-top);
      if(visible>vh*0.3&&visible>bestScore){
        bestScore=visible;best=s;
      }
    });
    
    // hero, contact 영역에서는 숨김 (이미 CTA가 있음)
    const scrollY=window.scrollY;
    const contactEl=document.getElementById('contact');
    if(scrollY<vh*0.4||(contactEl&&contactEl.getBoundingClientRect().top<vh*0.5)){
      chip.classList.remove('show');
      current=null;
      return;
    }

    if(best&&best.id!==current){
      current=best.id;
      const ctx=ctxMap[best.id];
      chipText.innerHTML='<strong>'+ctx.label+'</strong>&nbsp;<span class="ctx-chip-slot">'+ctx.slot+'</span>';
      chipCta.textContent=ctx.cta;
      chipCta.href=ctx.href;
      if(ctx.href.startsWith('http')){chipCta.target='_blank';chipCta.rel='noopener'}
      else{chipCta.removeAttribute('target');chipCta.removeAttribute('rel')}
      if(!firstShow){
        setTimeout(()=>chip.classList.add('show'),500);
        firstShow=true;
      }else{
        chip.classList.add('show');
      }
    }else if(!best){
      chip.classList.remove('show');
    }
  }

  window.addEventListener('scroll',()=>{
    if(scrollTimer)return;
    scrollTimer=setTimeout(()=>{updateChip();scrollTimer=null},120);
  },{passive:true});

  chipClose.addEventListener('click',()=>{
    chip.classList.remove('show');
    dismissed=true;
    sessionStorage.setItem('ctxChipDismissed','1');
  });

  // 초기 호출
  setTimeout(updateChip,800);
})();

/* ═══ P2-2 · SYSTEM STRIP — data-lp nodes are optional ═══ */
(function(){
  const els = {
    visits: document.querySelector('[data-lp="visits"]'),
    reviews: document.querySelector('[data-lp="reviews"]'),
    online: document.querySelector('[data-lp="online"]'),
  };
  if(!els.online) return;
  // 시드값 (DOM 초기값을 진실로 받음)
  let visits = parseInt((els.visits?.textContent||'387').replace(/,/g,''),10) || 387;
  let reviews = parseInt((els.reviews?.textContent||'1284').replace(/,/g,''),10) || 1284;
  let online = parseInt(els.online.textContent,10) || 23;
  const fmt = n => n.toLocaleString('en-US');
  function flash(el){
    if(!el) return;
    el.style.transition = 'color .25s';
    el.style.color = 'var(--gold-dark)';
    setTimeout(()=>{ el.style.color = ''; }, 350);
  }
  // 온라인 인원 — 8~14초 간격 ±1~3 변동, 18~32 사이 유지
  function tickOnline(){
    const delta = (Math.random() < 0.5 ? -1 : 1) * (1 + Math.floor(Math.random()*3));
    online = Math.max(18, Math.min(32, online + delta));
    els.online.textContent = online;
    flash(els.online);
    setTimeout(tickOnline, 8000 + Math.random()*6000);
  }
  // 방문 — 35~70초 간격 +1
  function tickVisits(){
    visits += 1;
    if(els.visits) els.visits.textContent = fmt(visits);
    flash(els.visits);
    setTimeout(tickVisits, 35000 + Math.random()*35000);
  }
  // 리뷰 — 90~180초 간격 +1
  function tickReviews(){
    reviews += 1;
    if(els.reviews) els.reviews.textContent = fmt(reviews);
    flash(els.reviews);
    setTimeout(tickReviews, 90000 + Math.random()*90000);
  }
  // IntersectionObserver — 보일 때만 작동
  const sec = document.querySelector('.live-proof');
  if(!sec) return;
  let started = false;
  const io = new IntersectionObserver(es=>{
    es.forEach(e=>{
      if(e.isIntersecting && !started){
        started = true;
        setTimeout(tickOnline, 4000);
        setTimeout(tickVisits, 12000);
        setTimeout(tickReviews, 25000);
      }
    });
  },{threshold:.3});
  io.observe(sec);
})();

/* ═══ RECOVERY TIMELINE ═══ */
(function(){
