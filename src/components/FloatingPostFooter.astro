    console.error('[consult] submit failed:',err);
    btn.disabled=false;btn.textContent='BASELINE 상담 신청';
    alert('전송 중 오류가 발생했습니다. 잠시 후 다시 시도하시거나, 긴급하시면 카카오톡 상담을 이용해 주세요.');
