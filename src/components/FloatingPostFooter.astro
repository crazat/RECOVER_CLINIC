(function(){
  const grid=document.querySelector('.ba-grid');
  const bar=document.querySelector('.ba-filter');
  if(!grid||!bar)return;
  const cards=[...grid.querySelectorAll('.ba-card')];
  // Derive metadata from each card text
  const concernMap={
    '흉터':'흉터','흉':'흉터',
    '붉은':'붉은기','홍조':'붉은기','여드름':'붉은기',
    '리프팅':'리프팅','주름':'리프팅','턱선':'리프팅','눈가':'리프팅','팔자':'리프팅','비대칭':'리프팅',
    '물광':'탄력','건조':'탄력','탄력':'탄력','결':'탄력'
  };
  cards.forEach(c=>{
    const tag=(c.querySelector('.ba-tag')||{}).textContent||'';
    const title=(c.querySelector('.ba-title')||{}).textContent||'';
    const prof=(c.querySelector('.ba-profile')||{}).textContent||'';
    let concern='흉터';
    const hay=tag+' '+title;
    for(const k in concernMap){if(hay.indexOf(k)>-1){concern=concernMap[k];break}}
    const gender=/여성/.test(prof)?'여성':(/남성/.test(prof)?'남성':'');
    const ageM=prof.match(/(\d0)대/);
    let ageBucket='';
    if(ageM){const n=parseInt(ageM[1],10);ageBucket=n<=20?'20':n===30?'30':'40';}
    c.dataset.concern=concern;
    c.dataset.gender=gender;
    c.dataset.age=ageBucket;
  });
  // Count chips
  const countFor=(type,val)=>{
    if(type==='all')return cards.length;
    return cards.filter(c=>c.dataset[type]===val).length;
  };
  bar.querySelectorAll('.ba-chip-n').forEach(span=>{
    const key=span.dataset.count;
    if(key==='all'){span.textContent=cards.length;return}
    const [t,v]=key.split(':');
    span.textContent=countFor(t,v);
  });
  const status=document.querySelector('.ba-filter-status');
  let cur={type:'all',value:'all'};
  function apply(){
    let shown=0;
    cards.forEach(c=>{
      const ok=cur.type==='all'||c.dataset[cur.type]===cur.value;
      c.classList.toggle('ba-hidden',!ok);
      if(ok)shown++;
    });
    if(status){
      status.textContent=cur.type==='all'?'':`${shown}건 표시 중`;
    }
    // reset scroll + arrow recompute
    grid.scrollLeft=0;
    grid.dispatchEvent(new Event('scroll'));
  }
  bar.addEventListener('click',e=>{
    const b=e.target.closest('.ba-chip');
    if(!b)return;
    cur={type:b.dataset.fType,value:b.dataset.fValue};
    bar.querySelectorAll('.ba-chip').forEach(x=>{
      const on=x===b;x.classList.toggle('active',on);
      x.setAttribute('aria-selected',on?'true':'false');
    });
    apply();
  });
})();

