let consultStep=0;
function setConsultStep(s){
  consultStep=s;
  if(consultSteps)consultSteps.style.transform=`translateX(-${s*(100/3)}%)`;
  csDots.forEach((d,i)=>{d.classList.remove('active','done');if(i<s)d.classList.add('done');else if(i===s)d.classList.add('active')});
  csLabels.forEach((l,i)=>l.classList.toggle('active',i===s));
