<script is:inline>
/* Logo bg removal */
function removeLogoBg(img,container,h){
  const c=document.createElement('canvas'),t=new Image();
  t.crossOrigin='anonymous';
  t.onload=function(){
    c.width=t.naturalWidth;c.height=t.naturalHeight;
    const ctx=c.getContext('2d');ctx.drawImage(t,0,0);
    const d=ctx.getImageData(0,0,c.width,c.height),px=d.data;
    for(let i=0;i<px.length;i+=4){if(px[i]>218&&px[i+1]>208&&px[i+2]>198)px[i+3]=0}
    ctx.putImageData(d,0,0);
    const o=new Image();o.src=c.toDataURL();o.style.height=h;o.style.width='auto';o.alt=img.alt;o.className='logo-clean';
    container.replaceChild(o,img);
  };t.src=img.src;
}
document.querySelectorAll('.nav-logo img').forEach(i=>{if(i.complete)removeLogoBg(i,i.parentElement,'64px');else i.onload=()=>removeLogoBg(i,i.parentElement,'64px')});
document.querySelectorAll('.footer-logo img').forEach(i=>{if(i.complete)removeLogoBg(i,i.parentElement,'64px');else i.onload=()=>removeLogoBg(i,i.parentElement,'64px')});

/* Hero emblem uses pre-processed R_emblem_forest.png — no JS needed */

/* Scroll progress */
const sp=document.getElementById('scrollProgress');
function updateScroll(){
  const h=document.documentElement.scrollHeight-window.innerHeight;
  sp.style.width=(scrollY/h*100)+'%';
  nav.classList.toggle('scrolled',scrollY>60);
}

/* Nav */
const nav=document.getElementById('nav');
window.addEventListener('scroll',updateScroll,{passive:true});

/* Mobile toggle */
const toggle=document.getElementById('navToggle'),links=document.getElementById('navLinks');
toggle.addEventListener('click',()=>{links.classList.toggle('open');const s=toggle.querySelectorAll('span'),o=links.classList.contains('open');s[0].style.transform=o?'rotate(45deg) translate(4px,4px)':'';s[1].style.opacity=o?'0':'';s[2].style.transform=o?'rotate(-45deg) translate(4px,-4px)':'';});
links.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{links.classList.remove('open');toggle.querySelectorAll('span').forEach(s=>{s.style.transform='';s.style.opacity=''})}));

/* B/A gallery: 12 cards reveal toggle (Phase 2 IA) */
(function(){
  const btn=document.getElementById('baExpandBtn');if(!btn)return;
  const grid=document.querySelector('.ba-grid');if(!grid)return;
  const lbl=btn.querySelector('.ba-expand-label'),cnt=btn.querySelector('.ba-expand-count');
  btn.addEventListener('click',()=>{
    const open=grid.classList.toggle('ba-show-extra');
    btn.setAttribute('aria-expanded',open?'true':'false');
    if(lbl)lbl.textContent=open?'기본 6개만 보기':'전체 12개 회복 기록 보기';
    if(cnt)cnt.textContent=open?'−6':'+6';
  });
})();

/* Reviews: 10 cards reveal toggle (Phase 2 IA) */
(function(){
  const btn=document.getElementById('revExpandBtn');if(!btn)return;
  const grid=document.querySelector('.reviews-scroll');if(!grid)return;
  const lbl=btn.querySelector('.rev-expand-label'),cnt=btn.querySelector('.rev-expand-count');
  btn.addEventListener('click',()=>{
    const open=grid.classList.toggle('rev-show-extra');
    btn.setAttribute('aria-expanded',open?'true':'false');
    if(lbl)lbl.textContent=open?'기본 4개만 보기':'전체 10개 회복 이야기 보기';
    if(cnt)cnt.textContent=open?'−6':'+6';
  });
})();

/* Reveal */
const ro=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');ro.unobserve(e.target)}})},{threshold:.08,rootMargin:'0px 0px -32px 0px'});
document.querySelectorAll('.rv').forEach(el=>ro.observe(el));

/* Smooth anchors */
document.querySelectorAll('a[href^="#"]').forEach(a=>{a.addEventListener('click',function(e){e.preventDefault();const t=document.querySelector(this.getAttribute('href'));if(t)window.scrollTo({top:t.getBoundingClientRect().top+scrollY-90,behavior:'smooth'})})});

/* Counters - refined easing */
const cObs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){const el=e.target,tgt=+el.dataset.target;const dur=2200;const start=performance.now();
  function step(now){const t=Math.min((now-start)/dur,1);const ease=1-Math.pow(1-t,4);const v=Math.floor(ease*tgt);el.textContent=v.toLocaleString();if(t<1)requestAnimationFrame(step);else{el.textContent=tgt.toLocaleString();el.classList.add('counted')}}
  requestAnimationFrame(step);cObs.unobserve(el)}})},{threshold:.4});
document.querySelectorAll('.counter').forEach(c=>cObs.observe(c));

/* Hero parallax */
const heroContent=document.querySelector('.hero-content');
const heroEmblem=document.querySelector('.hero-emblem-wrap');
const heroBranch=document.querySelector('.hero-branch');
const heroVine=document.querySelector('.hero-vine-right');
const heroNeural=document.querySelector('.hero-neural');
const heroScrollCue=document.querySelector('.hero-scroll');
window.addEventListener('scroll',()=>{
  if(scrollY<window.innerHeight){
    const r=scrollY/window.innerHeight;
    if(heroContent){heroContent.style.transform=`translateY(${r*40}px)`;heroContent.style.opacity=Math.max(0,1-r*1.6).toFixed(2)}
    if(heroEmblem){heroEmblem.style.transform=`translateY(calc(-50% + ${r*25}px))`;heroEmblem.style.opacity=Math.max(0,.85-r*1.4).toFixed(2)}
    if(heroBranch){heroBranch.style.transform=`translateY(${r*-15}px)`;heroBranch.style.opacity=Math.max(0,1-r*2).toFixed(2)}
    if(heroVine){heroVine.style.transform=`translateY(${r*-20}px)`;heroVine.style.opacity=Math.max(0,1-r*2).toFixed(2)}
    if(heroNeural)heroNeural.style.opacity=Math.max(0,.4-r*.6).toFixed(2);
    if(heroScrollCue)heroScrollCue.style.opacity=Math.max(0,1-r*4).toFixed(2);
  }
},{passive:true});

/* FAQ toggle */
document.querySelectorAll('.faq-q').forEach(q=>{q.addEventListener('click',()=>{const item=q.parentElement;const wasOpen=item.classList.contains('open');document.querySelectorAll('.faq-item.open').forEach(i=>i.classList.remove('open'));if(!wasOpen)item.classList.add('open')})});

/* Float CTA show on scroll */
const floatCta=document.getElementById('floatCta');
const scrollTopBtn=document.getElementById('scrollTop');
function updateFloat(){floatCta&&floatCta.classList.toggle('show',scrollY>400)}
window.addEventListener('scroll',updateFloat,{passive:true});
scrollTopBtn&&scrollTopBtn.addEventListener('click',()=>window.scrollTo({top:0,behavior:'smooth'}));

/* Neural canvas */
(function(){
  const cvs=document.getElementById('neuralCanvas');if(!cvs)return;
  const ctx=cvs.getContext('2d');let w,h,nodes=[],f=0,mouseX=-999,mouseY=-999;const G='196,162,101';
  cvs.addEventListener('mousemove',e=>{const rect=cvs.getBoundingClientRect();mouseX=e.clientX-rect.left;mouseY=e.clientY-rect.top});
  cvs.addEventListener('mouseleave',()=>{mouseX=-999;mouseY=-999});
  function resize(){w=cvs.width=cvs.offsetWidth;h=cvs.height=cvs.offsetHeight;nodes=[];
    const n=Math.floor(w*h/35000);for(let i=0;i<n;i++)nodes.push({x:Math.random()*w,y:Math.random()*h,vx:(Math.random()-.5)*.1,vy:(Math.random()-.5)*.1,r:Math.random()*1.8+1.2,p:Math.random()*Math.PI*2})}
  function draw(){ctx.clearRect(0,0,w,h);f+=.005;
    nodes.forEach(n=>{
      if(mouseX>0){const dx=n.x-mouseX,dy=n.y-mouseY,d=Math.sqrt(dx*dx+dy*dy);
        if(d<150&&d>0){const force=.12*(1-d/150);n.vx+=dx/d*force;n.vy+=dy/d*force}}
      n.vx*=.985;n.vy*=.985;
      n.x+=n.vx;n.y+=n.vy;if(n.x<0||n.x>w)n.vx*=-1;if(n.y<0||n.y>h)n.vy*=-1;
      const pulse=Math.sin(f+n.p)*.3+.7;
      nodes.forEach(m=>{const dx=m.x-n.x,dy=m.y-n.y,d=Math.sqrt(dx*dx+dy*dy);
        if(d<160&&d>0){const a=(1-d/160)*.08*pulse;ctx.strokeStyle=`rgba(${G},${a})`;ctx.lineWidth=.4;
          ctx.beginPath();const mx=(n.x+m.x)/2+Math.sin(f*2+n.p)*8,my=(n.y+m.y)/2+Math.cos(f*2+m.p)*8;
          ctx.moveTo(n.x,n.y);ctx.quadraticCurveTo(mx,my,m.x,m.y);ctx.stroke()}});
      ctx.fillStyle=`rgba(${G},${pulse*.18})`;ctx.beginPath();ctx.arc(n.x,n.y,n.r*pulse,0,Math.PI*2);ctx.fill();
      ctx.strokeStyle=`rgba(${G},${pulse*.06})`;ctx.lineWidth=.3;ctx.beginPath();ctx.arc(n.x,n.y,n.r*3*pulse,0,Math.PI*2);ctx.stroke()});
    requestAnimationFrame(draw)}
  resize();draw();window.addEventListener('resize',resize)})();

/* ═══ PREMIUM INTERACTIONS ═══ */

/* Cursor ambient glow */
if(window.matchMedia('(hover:hover)').matches){
  const glow=document.createElement('div');glow.className='cursor-glow';document.body.appendChild(glow);
  let gx=0,gy=0,mx=0,my=0;
  document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;glow.classList.add('active')});
  document.addEventListener('mouseleave',()=>glow.classList.remove('active'));
  (function gl(){gx+=(mx-gx)*.08;gy+=(my-gy)*.08;glow.style.left=gx+'px';glow.style.top=gy+'px';requestAnimationFrame(gl)})();
}

/* Active nav section tracking — DISABLED for multi-page IA (Phase I rev5)
   기존 single-page 시절 anchor 기반 IntersectionObserver가 SSR active를
   스크롤마다 toggle 제거하던 버그 해결. 멀티페이지에서는 SSR active 그대로 유지. */
const navAnchors=document.querySelectorAll('.nav-links a:not(.nav-cta)');
const isAnchorNav=Array.from(navAnchors).some(a=>(a.getAttribute('href')||'').startsWith('#'));
if(isAnchorNav){
  const navSections=document.querySelectorAll('section[id]');
  const secObserver=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){const id=e.target.id;
    navAnchors.forEach(a=>{a.classList.toggle('active',a.getAttribute('href')==='#'+id)})}})},{threshold:.25,rootMargin:'-90px 0px -50% 0px'});
  navSections.forEach(s=>secObserver.observe(s));
}

/* Shift+휠로만 가로 스크롤 변환 (일반 세로 휠은 페이지 스크롤 통과) */
document.querySelectorAll('.ba-grid,.reviews-scroll').forEach(el=>{
  el.addEventListener('wheel',e=>{
    // 가로 의도(트랙패드 가로 스와이프 등)면 브라우저 기본
    if(Math.abs(e.deltaX)>=Math.abs(e.deltaY))return;
    // Shift+휠일 때만 세로→가로 변환
    if(!e.shiftKey)return;
    const maxL=el.scrollWidth-el.clientWidth;
    const atStart=el.scrollLeft<=0;
    const atEnd=el.scrollLeft>=maxL-1;
    if((e.deltaY<0 && atStart)||(e.deltaY>0 && atEnd))return;
    e.preventDefault();el.scrollLeft+=e.deltaY;
  },{passive:false})});

/* Scroll nav arrows */
document.querySelectorAll('.scroll-arr').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const target=document.querySelector(btn.dataset.target);if(!target)return;
    const dir=btn.classList.contains('left')?-1:1;
    target.scrollBy({left:dir*340,behavior:'smooth'})})});
/* Update arrow visibility on scroll */
document.querySelectorAll('.scroll-nav').forEach(nav=>{
  const container=nav.querySelector('.ba-grid,.reviews-scroll');if(!container)return;
  const leftArr=nav.querySelector('.scroll-arr.left'),rightArr=nav.querySelector('.scroll-arr.right');
  function updateArrows(){
    const atStart=container.scrollLeft<10;
    const atEnd=container.scrollLeft>=container.scrollWidth-container.clientWidth-10;
    if(leftArr)leftArr.classList.toggle('hide',atStart);
    if(rightArr)rightArr.classList.toggle('hide',atEnd)}
  container.addEventListener('scroll',updateArrows,{passive:true});updateArrows()});

/* BA Gallery drag-to-scroll */
const baGrid=document.querySelector('.ba-grid');
if(baGrid){let bDown=false,bStartX,bScrollL;
  baGrid.addEventListener('mousedown',e=>{bDown=true;bStartX=e.pageX-baGrid.offsetLeft;bScrollL=baGrid.scrollLeft;baGrid.style.scrollBehavior='auto'});
  baGrid.addEventListener('mouseleave',()=>bDown=false);
  baGrid.addEventListener('mouseup',()=>{bDown=false;baGrid.style.scrollBehavior='smooth'});
  baGrid.addEventListener('mousemove',e=>{if(!bDown)return;e.preventDefault();const x=e.pageX-baGrid.offsetLeft;baGrid.scrollLeft=bScrollL-(x-bStartX)*1.5})}

/* ═══ BA SLIDER (featured) ═══ */
(function(){
  document.querySelectorAll('.ba-card[data-ba-slider]').forEach(card=>{
    const wrap=card.querySelector('.ba-img-wrap');if(!wrap)return;
    const src=card.dataset.baSlider;
    // Build layers
    const after=document.createElement('div');after.className='ba-slider-layer ba-slider-after';after.style.backgroundImage=`url(${src})`;
    const before=document.createElement('div');before.className='ba-slider-layer ba-slider-before';before.style.backgroundImage=`url(${src})`;
    const bBadge=document.createElement('span');bBadge.className='ba-slider-badge before';bBadge.textContent='BEFORE';
    const aBadge=document.createElement('span');aBadge.className='ba-slider-badge after';aBadge.textContent='AFTER';
    const div=document.createElement('div');div.className='ba-slider-div';
    const handle=document.createElement('div');handle.className='ba-slider-handle';handle.setAttribute('aria-label','드래그하여 비교');handle.setAttribute('role','slider');handle.setAttribute('tabindex','0');handle.setAttribute('aria-valuemin','0');handle.setAttribute('aria-valuemax','100');handle.setAttribute('aria-valuenow','50');
    wrap.appendChild(after);wrap.appendChild(before);wrap.appendChild(bBadge);wrap.appendChild(aBadge);wrap.appendChild(div);wrap.appendChild(handle);
    let split=50;
    function set(pct){
      split=Math.max(5,Math.min(95,pct));
      wrap.style.setProperty('--split',split+'%');
      handle.setAttribute('aria-valuenow',Math.round(split));
    }
    set(50);
    let dragging=false;
    function getPct(e){
      const r=wrap.getBoundingClientRect();
      const x=(e.touches?e.touches[0].clientX:e.clientX)-r.left;
      return (x/r.width)*100;
    }
    function start(e){dragging=true;card.classList.add('ba-dragging','ba-interacted');set(getPct(e));e.preventDefault();}
    function move(e){if(!dragging)return;set(getPct(e));}
    function end(){dragging=false;card.classList.remove('ba-dragging');}
    wrap.addEventListener('mousedown',start);
    wrap.addEventListener('touchstart',start,{passive:false});
    window.addEventListener('mousemove',move);
    window.addEventListener('touchmove',move,{passive:true});
    window.addEventListener('mouseup',end);
    window.addEventListener('touchend',end);
    // Click-to-position (without drag)
    wrap.addEventListener('click',e=>{if(!dragging)set(getPct(e));card.classList.add('ba-interacted');});
    // Keyboard
    handle.addEventListener('keydown',e=>{
      if(e.key==='ArrowLeft'){set(split-5);e.preventDefault();card.classList.add('ba-interacted');}
      else if(e.key==='ArrowRight'){set(split+5);e.preventDefault();card.classList.add('ba-interacted');}
      else if(e.key==='Home'){set(5);e.preventDefault();}
      else if(e.key==='End'){set(95);e.preventDefault();}
    });
    // Auto-teaser animation on scroll-in (once)
    const io=new IntersectionObserver(es=>{es.forEach(e=>{
      if(!e.isIntersecting||card.classList.contains('ba-interacted'))return;
      io.unobserve(card);
      let t=0;const anim=setInterval(()=>{
        t+=1;
        const p=50+Math.sin(t*.25)*18*Math.exp(-t*.08);
        set(p);
        if(t>30){clearInterval(anim);set(50);}
      },50);
    })},{threshold:.4});
    io.observe(card);
  });
})();

/* ═══ BA CINEMA — Featured spotlight slider ═══ */
(function(){
  const stage=document.querySelector('#ba-cinema-feat .ba-cinema-stage');
  const cinema=document.querySelector('#ba-cinema-feat');
  if(!stage||!cinema)return;
  const src=cinema.dataset.cinemaSrc;
  const before=stage.querySelector('.ba-cinema-before');
  const after=stage.querySelector('.ba-cinema-after');
  before.style.backgroundImage=`url(${src})`;
  after.style.backgroundImage=`url(${src})`;
  let split=50;
  function set(p){
    split=Math.max(4,Math.min(96,p));
    stage.style.setProperty('--csplit',split+'%');
    stage.setAttribute('aria-valuenow',Math.round(split));
  }
  set(50);
  let dragging=false;
  function getPct(e){
    const r=stage.getBoundingClientRect();
    const x=(e.touches?e.touches[0].clientX:e.clientX)-r.left;
    return (x/r.width)*100;
  }
  function start(e){dragging=true;stage.classList.add('cinema-dragging','cinema-touched');set(getPct(e));e.preventDefault();}
  function move(e){if(!dragging)return;set(getPct(e));}
  function end(){dragging=false;stage.classList.remove('cinema-dragging');}
  stage.addEventListener('mousedown',start);
  stage.addEventListener('touchstart',start,{passive:false});
  window.addEventListener('mousemove',move);
  window.addEventListener('touchmove',move,{passive:true});
  window.addEventListener('mouseup',end);
  window.addEventListener('touchend',end);
  stage.addEventListener('keydown',e=>{
    if(e.key==='ArrowLeft'){set(split-4);e.preventDefault();stage.classList.add('cinema-touched');}
    else if(e.key==='ArrowRight'){set(split+4);e.preventDefault();stage.classList.add('cinema-touched');}
    else if(e.key==='Home'){set(4);e.preventDefault();}
    else if(e.key==='End'){set(96);e.preventDefault();}
  });
  // Cinematic auto-reveal: slow sweep on first viewport entry
  const io=new IntersectionObserver(es=>{es.forEach(e=>{
    if(!e.isIntersecting||stage.classList.contains('cinema-touched'))return;
    io.unobserve(stage);
    let t=0;const total=80;
    const anim=setInterval(()=>{
      t++;
      // ease-in-out sweep: 50 → 88 → 12 → 50
      const phase=t/total;
      let p;
      if(phase<.35){const k=phase/.35;p=50+38*(1-Math.cos(k*Math.PI))/2;}
      else if(phase<.75){const k=(phase-.35)/.4;p=88-76*(1-Math.cos(k*Math.PI))/2;}
      else{const k=(phase-.75)/.25;p=12+38*(1-Math.cos(k*Math.PI))/2;}
      set(p);
      if(t>=total){clearInterval(anim);set(50);}
    },36);
  })},{threshold:.45});
  io.observe(stage);
})();

