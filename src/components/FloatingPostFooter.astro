<!-- ═══ PERSONA TOGGLE ═══ -->
<script is:inline>
(function(){
  const KEY='recover-persona';
  const btns=document.querySelectorAll('.pt-btn');
  if(!btns.length) return;
  function apply(p){
    document.documentElement.setAttribute('data-persona',p);
    // 헤드카피
    document.querySelectorAll('[data-gentle][data-focused]').forEach(el=>{
      const v=el.getAttribute('data-'+p);if(v)el.innerHTML=v;
    });
    // CTA 라벨
    document.querySelectorAll('[data-gentle-label][data-focused-label]').forEach(el=>{
      const v=el.getAttribute('data-'+p+'-label');if(!v)return;
      const span=el.querySelector('span:not(.arr)');
      if(span)span.textContent=v;else el.childNodes[0].nodeValue=v;
    });
    // 히어로 서브 CTA 하위 카피
    const sub=document.querySelector('.hero-cta-sub');
    if(sub){sub.textContent=p==='focused'?'리커버 강남 · 흉터 회복 조건 상담':'선릉역 7번 출구 앞 5층 · AI 피부 회복 조건 상담 준비 중';}
    // Result Slice 토글 동기화 (남성 우선)
    const rsBar=document.querySelector('.rs-results-toggle');
    if(rsBar){
      const target=p==='focused'?'male':'all';
      const tBtn=rsBar.querySelector('[data-rs-filter="'+target+'"]');
      if(tBtn&&!tBtn.classList.contains('active')){tBtn.click();}
    }
    // BA 갤러리 칩 (focused는 직진성 — 흉터 우선; gentle은 전체)
    const baBar=document.querySelector('.ba-filter');
    if(baBar){
      // 페르소나 변경 시 사용자가 직접 만진 칩이 아니면 전체로 리셋
      const all=baBar.querySelector('[data-f-value="all"]');
      if(all&&!all.classList.contains('active')){
        // 명시적 페르소나 변경에서만 리셋: persona 변경에 의한 호출은 user-select 상태 보존
      }
    }
    // 버튼 활성
    btns.forEach(b=>{
      const on=b.dataset.persona===p;
      b.classList.toggle('active',on);
      b.setAttribute('aria-selected',on?'true':'false');
    });
  }
  let init='gentle';
  try{const s=localStorage.getItem(KEY);if(s==='gentle'||s==='focused')init=s;}catch(e){}
  apply(init);
  btns.forEach(b=>b.addEventListener('click',()=>{
    const p=b.dataset.persona;
    apply(p);
    try{localStorage.setItem(KEY,p);}catch(e){}
  }));
})();
</script>

<!-- ═══ ESSAY EXPAND ═══ -->
<script is:inline>
(function(){
  document.querySelectorAll('.essay-expand-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const t=document.getElementById(btn.dataset.target);
      if(!t)return;
      const open=t.classList.toggle('is-open');
      btn.setAttribute('aria-expanded',open?'true':'false');
      const lbl=btn.querySelector('.essay-expand-label');
      if(lbl){
        const cur=lbl.textContent;
        lbl.dataset.closed=lbl.dataset.closed||cur;
        lbl.textContent=open?'접기':lbl.dataset.closed;
      }
      if(open){
        // no hidden attribute prevents transition; remove it
        t.removeAttribute('hidden');
      }
    });
    // ensure hidden attr removed on init so CSS transitions can render 0-height
    const t=document.getElementById(btn.dataset.target);
    if(t&&t.hasAttribute('hidden')){t.removeAttribute('hidden');}
  });
})();
</script>
