const cB3=document.getElementById('consultBack3');if(cB3)cB3.addEventListener('click',()=>setConsultStep(1));

if(consultForm)consultForm.addEventListener('submit',async e=>{e.preventDefault();
  const method=document.getElementById('cMethod'),time=document.getElementById('cTime'),agree=document.getElementById('cAgree');
  const nameEl=document.getElementById('cName'),phoneEl=document.getElementById('cPhone');
  if(!nameEl.value.trim()){setConsultStep(1);shakeEl(nameEl);nameEl.focus();return}
  if(!phoneEl.value.trim()||phoneEl.value.trim().length<8){setConsultStep(1);shakeEl(phoneEl);phoneEl.focus();return}
  if(!method.value){shakeEl(method);return}
  if(!time.value){shakeEl(time);return}
  if(agree&&!agree.checked){shakeEl(agree.closest('.consult-consent'));return}
  const btn=document.getElementById('consultSubmit');
  btn.disabled=true;btn.textContent='전송 중...';
  const payload={
    name:nameEl.value.trim(),
    phone:phoneEl.value.trim(),
    concern:document.getElementById('cConcern').value||'',
    method:method.value,
    timeslot:time.value,
    memo:(document.getElementById('cMemo').value||'').trim(),
    userAgent:(navigator.userAgent||'').slice(0,300),
    referrer:(document.referrer||'').slice(0,300)
  };
  try{
    if(typeof window.__submitConsult==='function'){
      await window.__submitConsult(payload);
    }else{
      await new Promise(r=>setTimeout(r,600));
      console.warn('[consult] Firestore SDK not ready; payload logged only:',payload);
    }
    btn.classList.add('sent');btn.textContent='✓ 신청 완료';
    setTimeout(()=>{btn.classList.remove('sent');btn.disabled=false;btn.textContent='BASELINE 상담 신청';
