/* ═══ AI SELF DIAGNOSIS QUIZ ═══ */
(function(){
  const card = document.getElementById('dgCard');
  if(!card) return;
  const steps = card.querySelectorAll('.dg-step');
  const progFill = document.getElementById('dgProgress');
  const progText = document.getElementById('dgProgressText');
  const btnPrev = document.getElementById('dgPrev');
  const btnNext = document.getElementById('dgNext');
  const nav = document.getElementById('dgNav');
  const resultEl = document.getElementById('dgResult');
  const totalSteps = steps.length;
  let current = 1;
  const answers = {};

  // Load persisted answers
  try{
    const saved = JSON.parse(localStorage.getItem('dg-answers')||'{}');
    Object.assign(answers, saved);
  }catch(e){}

  function updateUI(){
    steps.forEach(s=>s.classList.toggle('active', +s.dataset.step === current));
    const pct = (current/totalSteps)*100;
    progFill.style.width = pct+'%';
    progText.textContent = `Q${current} · of ${totalSteps}`;
    btnPrev.disabled = current===1;
    btnNext.disabled = !answers[current];
    btnNext.innerHTML = current===totalSteps
      ? '결과 보기 <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M8 4l3 3-3 3" stroke-linecap="round"/></svg>'
      : '다음 <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M8 4l3 3-3 3" stroke-linecap="round"/></svg>';
    // Restore selections for current step
    steps.forEach(s=>{
      const q = +s.dataset.step;
      s.querySelectorAll('.dg-opt').forEach(o=>{
        o.classList.toggle('selected', answers[q] === o.dataset.v);
      });
    });
  }

  card.addEventListener('click', e=>{
    const opt = e.target.closest('.dg-opt');
    if(!opt) return;
    const q = +opt.dataset.q;
    answers[q] = opt.dataset.v;
    try{ localStorage.setItem('dg-answers', JSON.stringify(answers)); }catch(e){}
    // Visually select
    const step = opt.closest('.dg-step');
    step.querySelectorAll('.dg-opt').forEach(o=>o.classList.remove('selected'));
    opt.classList.add('selected');
    btnNext.disabled = false;
  });

  btnNext.addEventListener('click', ()=>{
    if(!answers[current]) return;
    if(current < totalSteps){ current++; updateUI(); }
    else { showResult(); }
  });
  btnPrev.addEventListener('click', ()=>{
    if(current>1){ current--; updateUI(); }
  });

  function showResult(){
    steps.forEach(s=>s.classList.remove('active'));
    nav.style.display='none';
    resultEl.classList.add('active');
    progFill.style.width = '100%';
    progText.textContent = 'Result · 완료';

    // Build diagnosis
    const concernMap = {
      scar:{title:'흉터 재생 경로', summary:'반복된 여드름이나 흉터 조직의 재생을 우선 목표로 합니다. 피부 안쪽 조직 재구성을 유도하는 접근이 가장 효과적입니다.', tag:'scar', caseId:'2', caseLabel:'27세 남성 · 여드름 흉터 케이스',
        twin:{img:'assets/ba_6.webp', age:'20대 여성', concern:'복합 여드름 흉터', score:92, note:'같은 유형의 패인 자국·붉은 자국을 6개월에 걸쳐 재생한 사례입니다.'}},
      sensitive:{title:'장벽 복원 경로', summary:'자극에 과민해진 피부에는 먼저 "쉼"이 필요합니다. 비침습 케어로 장벽을 되살린 후에 시술을 고려합니다.', tag:'barrier', caseId:'1', caseLabel:'42세 여성 · 장벽 손상 케이스',
        twin:{img:'assets/ba_skin_add_3.webp', age:'30대 여성', concern:'만성 홍조 & 열감', score:88, note:'화장품 바꾸면 바로 반응하던 상태에서 장벽을 복원한 사례입니다.'}},
      aging:{title:'탄력 회복 경로', summary:'탄력 저하는 콜라겐 합성 능력 저하의 신호입니다. 체내 환경을 먼저 개선하고 외부 자극을 함께 주는 복합 접근을 권합니다.', tag:'aging', caseId:'3', caseLabel:'51세 여성 · 탄력 + 기미 케이스',
        twin:{img:'assets/ba_skin_lifting_k.webp', age:'50대 여성', concern:'턱선 · 불독살 리프팅', score:90, note:'수술 없이 근막 리프팅으로 처짐을 자연스럽게 끌어올린 사례입니다.'}},
      dullness:{title:'톤 균형 경로', summary:'칙칙함과 색소는 혈행·대사 이슈와 연결됩니다. 체질 기반 한약으로 내부 순환을 먼저 개선하는 것이 지속 효과에 유리합니다.', tag:'tone', caseId:'3', caseLabel:'51세 여성 · 기미 + 탄력 케이스',
        twin:{img:'assets/ba_skin_glow_k.webp', age:'30대 여성', concern:'물광 · 톤 업', score:86, note:'직장인이 중요한 일정을 앞두고 3개월에 걸쳐 톤을 끌어올린 사례입니다.'}},
    };
    const base = concernMap[answers[1]] || concernMap.scar;

    // Recommendations
    let recs = [];
    const approach = answers[4];
    const history = answers[2];
    const condition = answers[3];

    if(approach==='gentle' || condition==='reactive' || history==='heavy'){
      recs = [
        {tag:'Step 1', name:'체질 맞춤 한약', desc:'내부 환경부터 안정화'},
        {tag:'Step 2', name:'약침 · 침치료', desc:'비침습 경혈 자극으로 순환 개선'},
      ];
    } else if(approach==='focused'){
      recs = [
        {tag:'Step 1', name:'새살침 프로토콜', desc:'집중 회차로 흉터·조직 재생'},
        {tag:'Step 2', name:'맞춤 한약 병용', desc:'재생 환경 유지 & 증폭'},
      ];
    } else {
      recs = [
        {tag:'Step 1', name:'한약 + 새살침 복합', desc:'균형 잡힌 표준 프로토콜'},
        {tag:'Step 2', name:'경과 기반 조정', desc:'4주 재분석 후 회차 재설정'},
      ];
    }

    // Caution based on history/condition
    let caution = '';
    if(history==='heavy' || history==='laser'){
      caution = '이전 시술 이력이 많은 편이므로, <strong style="color:var(--forest);font-weight:500">첫 1~2개월은 자극성 시술을 보류</strong>하고 피부 장벽 회복기를 먼저 가지시는 것을 권장합니다.';
    } else if(condition==='reactive'){
      caution = '피부가 외부 자극에 민감한 상태입니다. <strong style="color:var(--forest);font-weight:500">약한 강도부터 단계적으로 접근</strong>하며, 재평가 주기를 짧게(2주) 가져가는 것을 권장합니다.';
    } else if(condition==='tired'){
      caution = '컨디션 저하가 지속되는 경우 <strong style="color:var(--forest);font-weight:500">체내 수분·영양 대사 불균형</strong>이 원인일 수 있습니다. 체질 분석을 통해 내부 원인부터 확인하는 것이 좋습니다.';
    } else {
      caution = '전반적으로 안정적인 상태이므로 <strong style="color:var(--forest);font-weight:500">표준 프로토콜로 진행</strong>이 가능합니다. 단, 개인 반응에 따라 회차는 조정됩니다.';
    }

    document.getElementById('dgResultTitle').innerHTML = `당신의 피부는 <em>${base.title}</em>이<br>가장 적합해 보입니다`;
    document.getElementById('dgResultSummary').textContent = base.summary;
    document.getElementById('dgResultRecs').innerHTML = recs.map(r=>
      `<div class="dg-rec"><span class="dg-rec-tag">${r.tag}</span><strong style="display:block;margin-bottom:3px;font-weight:500;color:var(--forest-deep)">${r.name}</strong><span style="font-size:12px;opacity:.7">${r.desc}</span></div>`
    ).join('');
    document.getElementById('dgResultCaution').innerHTML = caution;

    // ViewCase 버튼에 caseId 주입 & 텍스트 업데이트
    const viewBtn = document.getElementById('dgViewCase');
    if(viewBtn && base.caseId){
      viewBtn.dataset.caseId = base.caseId;
      viewBtn.innerHTML = `${base.caseLabel} 보기 <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M8 4l3 3-3 3" stroke-linecap="round"/></svg>`;
    }

    // UP-1: Twin Finder 렌더
    if(base.twin){
      const tw = document.getElementById('dgTwin');
      const twImg = document.getElementById('dgTwinImg');
      const twTitle = document.getElementById('dgTwinTitle');
      const twSub = document.getElementById('dgTwinSub');
      const twScore = document.getElementById('dgTwinScore');
      const twFill = document.getElementById('dgTwinFill');
      const twNote = document.getElementById('dgTwinNote');
      if(tw && twImg){
        tw.hidden = false;
        twImg.src = base.twin.img;
        twImg.alt = `${base.twin.age} · ${base.twin.concern} Before/After`;
        twTitle.innerHTML = `${base.twin.age} · <em>${base.twin.concern}</em>`;
        twSub.textContent = '당신의 현재 상태와 가장 가까운 프로파일이에요.';
        twScore.textContent = '0';
        twFill.style.width = '0%';
        twNote.textContent = base.twin.note;
        // Animate score
        setTimeout(()=>{
          const target = base.twin.score;
          const start = performance.now();
          const dur = 1100;
          const tick = (t)=>{
            const p = Math.min(1, (t-start)/dur);
            const eased = 1 - Math.pow(1-p, 3);
            const v = Math.round(target * eased);
            twScore.textContent = v;
            twFill.style.width = (v)+'%';
            if(p<1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        }, 350);
      }
    }
  }

  // Case Study 탭 오토-셀렉트 (결과에서 "비슷한 케이스 보기" 클릭 시)
  const viewCaseBtn = document.getElementById('dgViewCase');
  if(viewCaseBtn){
    viewCaseBtn.addEventListener('click', (e)=>{
      const cid = viewCaseBtn.dataset.caseId;
      if(!cid) return;
      // Case Study 탭 활성화
      setTimeout(()=>{
        const targetTab = document.querySelector(`.cs-tab[data-case="${cid}"]`);
        if(targetTab) targetTab.click();
      }, 450);
    });
  }

  document.getElementById('dgRestart').addEventListener('click', ()=>{
    Object.keys(answers).forEach(k=>delete answers[k]);
    try{ localStorage.removeItem('dg-answers'); }catch(e){}
    resultEl.classList.remove('active');
    nav.style.display='';
    current=1;
    updateUI();
    // 리드 폼 상태도 초기화
    const leadForm=document.getElementById('dgLeadForm');
    const leadDone=document.getElementById('dgLeadDone');
    if(leadForm&&leadDone){leadForm.hidden=false;leadDone.hidden=true;leadForm.reset();}
  });

  // ── Lead capture submit ──
  const leadForm=document.getElementById('dgLeadForm');
  const leadDone=document.getElementById('dgLeadDone');
  if(leadForm){
    leadForm.addEventListener('submit',async(e)=>{
      e.preventDefault();
      const btn=leadForm.querySelector('.dg-lead-submit');
      const fd=new FormData(leadForm);
      const name=(fd.get('name')||'').toString().trim();
      const phone=(fd.get('phone')||'').toString().trim();
      const channel=(fd.get('channel')||'kakao').toString();
      const consent=fd.get('consent');
      // 검증
      if(!name||!phone||!consent||!/^[0-9\-\s]{9,}$/.test(phone)){
        btn.classList.remove('shake');void btn.offsetWidth;btn.classList.add('shake');
        return;
      }
      // 자가 체크 결과 요약 수집
      const resultTitle=document.getElementById('dgResultTitle')?.textContent||'';
      const recTags=[...document.querySelectorAll('#dgResultRecs .dg-rec-tag')].map(el=>el.textContent.trim()).join(', ');
      const methodMap={kakao:'카카오톡',sms:'문자',call:'전화'};
      const payload={
        name,phone,
        concern:'자가체크',
        method:methodMap[channel]||'카카오톡',
        timeslot:'',
        memo:`[자가체크] ${resultTitle.replace(/\s+/g,' ').trim()} | 추천: ${recTags} | 응답: ${JSON.stringify(answers)}`.slice(0,500),
      };
      btn.disabled=true;
      try{
        if(typeof window.__submitConsult==='function'){
          await window.__submitConsult(payload);
        }else{
          await new Promise(r=>setTimeout(r,600));
        }
        leadForm.hidden=true;
        leadDone.hidden=false;
      }catch(err){
        console.warn('lead submit failed',err);
        btn.disabled=false;
        btn.classList.remove('shake');void btn.offsetWidth;btn.classList.add('shake');
      }
    });
  }

  // Initial
  updateUI();
  // If user had all answers saved and comes back, still start at 1
})();
</script>

