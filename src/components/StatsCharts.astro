---
// StatsCharts — 회복 만족도 분포 dot chart + 회복 기간 bell curve
const satisfactionBuckets = [
  { lbl: '1', n: 1 },
  { lbl: '2', n: 2 },
  { lbl: '3', n: 12 },
  { lbl: '4', n: 38 },
  { lbl: '5', n: 47 },
];
const totalResp = satisfactionBuckets.reduce((s, b) => s + b.n, 0);
---
<figure class="stats-charts" aria-label="회복 만족도 · 회복 기간 분포 차트">
  <div class="stats-charts-cap">
    <span class="stats-charts-eye">Recovery Distribution · Figure</span>
    <h3 class="stats-charts-title">회복은 평균이 아니라<br/><em>분포</em>로 봅니다</h3>
    <p class="stats-charts-sub">단일 만족도 점수가 아닌 분포 형태로, 회복 기간이 아닌 곡선의 모양으로 봅니다. 평균은 결정자의 판단을 흐립니다.</p>
  </div>

  <div class="stats-charts-grid">
    <!-- Chart 1: Satisfaction distribution -->
    <div class="stats-chart">
      <div class="stats-chart-head">
        <span class="stats-chart-num">{totalResp}</span>
        <div>
          <p class="stats-chart-lbl">회복 만족도 분포</p>
          <p class="stats-chart-meta">n = {totalResp} · 5점 척도 (RECOVER RECORD 기준)</p>
        </div>
      </div>
      <svg class="stats-chart-svg" viewBox="0 0 380 180" xmlns="http://www.w3.org/2000/svg">
        <!-- baseline -->
        <line x1="32" y1="160" x2="370" y2="160" stroke="#1A1A1A" stroke-width=".7"/>
        {satisfactionBuckets.map((b, i) => {
          const colW = 60;
          const cx = 60 + i * colW;
          const dots: any[] = [];
          for (let j = 0; j < b.n; j++) {
            const row = Math.floor(j / 6);
            const col = j % 6;
            const dx = cx + (col - 2.5) * 7;
            const dy = 154 - row * 8;
            dots.push({ dx, dy });
          }
          return (
            <g>
              {dots.map((d) => (
                <circle cx={d.dx} cy={d.dy} r="2.4" fill={b.lbl === '5' ? '#2D5F3E' : b.lbl === '4' ? '#4A8C5E' : b.lbl === '3' ? '#A88B4A' : '#7a3a3a'} opacity={b.lbl === '5' ? '.92' : '.7'}/>
              ))}
              <text x={cx} y={172} text-anchor="middle" font-family="IBM Plex Mono" font-size="10" fill="#5A5A5A" letter-spacing=".06em">{b.lbl}</text>
              <text x={cx} y={154 - Math.ceil(b.n / 6) * 8 - 6} text-anchor="middle" font-family="Fraunces" font-size="13" font-style="italic" fill="#1A1A1A" font-weight="500">{b.n}</text>
            </g>
          );
        })}
        <text x="32" y="22" font-family="IBM Plex Mono" font-size="9" fill="#A88B4A" letter-spacing=".18em">RESPONSES</text>
        <text x="200" y="14" text-anchor="middle" font-family="Noto Serif KR" font-size="9" fill="#5A5A5A" font-style="italic">"5점에 47명, 평균 4.31"</text>
      </svg>
      <p class="stats-chart-foot">FIG. 6a · Dot chart · 만족도 5점 분포</p>
    </div>

    <!-- Chart 2: Recovery duration bell curve -->
    <div class="stats-chart">
      <div class="stats-chart-head">
        <span class="stats-chart-num">12<em>주</em></span>
        <div>
          <p class="stats-chart-lbl">평균 회복 기간 분포</p>
          <p class="stats-chart-meta">중앙값 12주 · 4–24주 · 개인차 포함</p>
        </div>
      </div>
      <svg class="stats-chart-svg" viewBox="0 0 380 180" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="bellFill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#2D5F3E" stop-opacity=".18"/>
            <stop offset="100%" stop-color="#2D5F3E" stop-opacity="0"/>
          </linearGradient>
        </defs>
        <!-- baseline -->
        <line x1="32" y1="160" x2="370" y2="160" stroke="#1A1A1A" stroke-width=".7"/>
        <!-- Bell curve fill -->
        <path d="M40 160 Q60 158 80 150 Q100 138 120 120 Q140 90 170 64 Q200 50 230 64 Q260 90 280 120 Q300 138 320 150 Q340 158 360 160 Z" fill="url(#bellFill)"/>
        <!-- Bell curve stroke -->
        <path d="M40 160 Q60 158 80 150 Q100 138 120 120 Q140 90 170 64 Q200 50 230 64 Q260 90 280 120 Q300 138 320 150 Q340 158 360 160" fill="none" stroke="#2D5F3E" stroke-width="1.6"/>
        <!-- Median marker -->
        <line x1="200" y1="50" x2="200" y2="160" stroke="#A88B4A" stroke-width="1" stroke-dasharray="3 2"/>
        <circle cx="200" cy="50" r="4.5" fill="#C4A265" stroke="#A88B4A" stroke-width="1"/>
        <text x="200" y="42" text-anchor="middle" font-family="Fraunces" font-size="13" font-style="italic" font-weight="500" fill="#A88B4A">12주</text>
        <!-- X-axis labels -->
        <g font-family="IBM Plex Mono" font-size="10" fill="#5A5A5A" letter-spacing=".06em" text-anchor="middle">
          <text x="50" y="174">4주</text>
          <text x="125" y="174">8주</text>
          <text x="200" y="174">12주</text>
          <text x="275" y="174">16주</text>
          <text x="350" y="174">24주</text>
        </g>
        <text x="32" y="22" font-family="IBM Plex Mono" font-size="9" fill="#A88B4A" letter-spacing=".18em">FREQUENCY</text>
        <text x="200" y="14" text-anchor="middle" font-family="Noto Serif KR" font-size="9" fill="#5A5A5A" font-style="italic">"한 달도, 두 달도, 여섯 달도 — 같은 회복은 없다"</text>
      </svg>
      <p class="stats-chart-foot">FIG. 6b · Bell curve · 회복 기간 분포 (관찰 기반)</p>
    </div>
  </div>

  <p class="stats-charts-disc">* 차트는 RECOVER RECORD 내부 관찰 지표 기반 시각화이며, 임상 효능 또는 보장을 의미하지 않습니다. 개인의 회복 속도와 만족도는 피부 상태·생활 리듬에 따라 달라집니다.</p>
</figure>

<style>
.stats-charts{margin:48px 0;padding:40px clamp(20px,4vw,56px);background:white;border:1px solid rgba(26,26,26,.16);position:relative;box-shadow:0 1px 0 rgba(196,162,101,.16),0 16px 48px rgba(45,95,62,.05)}
.stats-charts::before{content:'';position:absolute;top:0;left:0;width:120px;height:2px;background:#A88B4A}
.stats-charts-cap{margin-bottom:32px;max-width:720px}
.stats-charts-eye{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.32em;color:#A88B4A;text-transform:uppercase;font-weight:500;display:inline-block;margin-bottom:12px}
.stats-charts-title{font-family:'Fraunces','Noto Serif KR',Georgia,serif;font-size:clamp(22px,3vw,30px);font-weight:300;color:#1A1A1A;line-height:1.28;letter-spacing:-.008em;margin-bottom:10px}
.stats-charts-title em{font-style:italic;color:#2D5F3E;font-weight:500}
.stats-charts-sub{font-family:'Noto Serif KR',Georgia,serif;font-size:14.5px;line-height:1.75;color:#3D3D3D;font-weight:300}
.stats-charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:32px}
@media(max-width:768px){.stats-charts-grid{grid-template-columns:1fr}}
.stats-chart{padding:22px;border:1px solid rgba(196,162,101,.22);background:#FBFAF6}
.stats-chart-head{display:flex;align-items:flex-start;gap:14px;margin-bottom:18px;padding-bottom:16px;border-bottom:1px solid rgba(196,162,101,.16)}
.stats-chart-num{font-family:'Fraunces',serif;font-size:42px;font-weight:300;color:#1A1A1A;line-height:.92;letter-spacing:-.014em}
.stats-chart-num em{font-style:italic;color:#2D5F3E;font-size:.5em;font-weight:400;margin-left:4px}
.stats-chart-lbl{font-family:'Fraunces','Noto Serif KR',serif;font-size:15.5px;font-weight:500;color:#1A1A1A;line-height:1.4;letter-spacing:-.005em}
.stats-chart-meta{font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.06em;color:#5A5A5A;margin-top:4px;line-height:1.6}
.stats-chart-svg{width:100%;height:auto;display:block;margin-top:8px}
.stats-chart-foot{margin-top:14px;padding-top:12px;border-top:1px solid rgba(196,162,101,.16);font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.18em;color:#5A5A5A;text-transform:uppercase;text-align:center}
.stats-charts-disc{margin-top:24px;padding-top:18px;border-top:1px solid rgba(196,162,101,.12);font-family:'Noto Serif KR',serif;font-size:11.5px;line-height:1.7;color:#5A5A5A;font-style:italic;font-weight:300}
</style>
