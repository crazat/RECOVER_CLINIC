---
import MainLayout from '../layouts/MainLayout.astro';
import RRRFlow from '../components/RRRFlow.astro';
import StatsCharts from '../components/StatsCharts.astro';
---
<MainLayout
  title="리커버한의원 강남 | 회복 조건을 보는 한의학 기반 피부 회복 설계"
  description="리커버한의원 강남은 한의학 기반 피부 회복 설계 브랜드입니다. AI 피부 분석으로 피부의 결, 흔적, 생활 리듬을 읽고 회복의 조건과 순서를 정리합니다. 선릉역 7번 출구 앞 5층, 2026.08.17 강남 개원."
  active="home"
  chapterCategory="회복 조건"
>
<section class="hero" id="hero">
  <div class="bg-botanical"></div>
  <canvas class="hero-neural" id="neuralCanvas"></canvas>
  <div class="gold-particles"><span class="gp"></span><span class="gp"></span><span class="gp"></span><span class="gp"></span><span class="gp"></span><span class="gp"></span></div>
  <div class="hero-branch"><svg viewBox="0 0 200 300" fill="none" stroke="#C4A265" stroke-width=".6">
    <path d="M100 300C100 280 100 240 98 200C96 160 104 130 108 100C112 70 120 45 125 25C128 15 126 5 122 0" opacity=".4"/>
    <path d="M108 100C120 90 136 88 155 92" opacity=".3"/>
    <ellipse cx="155" cy="92" rx="22" ry="30" transform="rotate(-5,155,92)" opacity=".18"/>
    <path d="M145 88C150 80 158 76 165 74" opacity=".12"/>
    <path d="M100 160C82 148 60 145 38 150" opacity=".3"/>
    <ellipse cx="38" cy="150" rx="24" ry="32" transform="rotate(8,38,150)" opacity=".18"/>
    <path d="M48 146C42 138 34 134 26 136" opacity=".12"/>
    <path d="M100 200C115 190 132 185 150 188" opacity=".25"/>
    <ellipse cx="150" cy="188" rx="18" ry="25" transform="rotate(-8,150,188)" opacity=".15"/>
    <path d="M98 240C82 232 62 230 42 236" opacity=".2"/>
    <ellipse cx="42" cy="236" rx="16" ry="22" transform="rotate(5,42,236)" opacity=".12"/>
    <ellipse cx="122" cy="25" rx="20" ry="28" transform="rotate(-12,122,25)" opacity=".2"/>
    <ellipse cx="132" cy="18" rx="14" ry="20" transform="rotate(-25,132,18)" opacity=".12"/>
    <circle cx="108" cy="100" r="2" opacity=".2"/><circle cx="100" cy="160" r="2" opacity=".18"/>
    <circle cx="100" cy="200" r="1.8" opacity=".15"/><circle cx="98" cy="240" r="1.5" opacity=".12"/>
    <path d="M155 92L155 72" stroke-width=".3" opacity=".1"/><path d="M38 150L38 130" stroke-width=".3" opacity=".1"/>
  </svg></div>
  <div class="hero-vine-right"><svg viewBox="0 0 60 200" fill="none" stroke="#C4A265" stroke-width=".5">
    <path d="M30 200C30 180 30 160 28 140C26 120 32 100 30 80C28 60 34 40 30 20C28 10 30 2 30 0" opacity=".35"/>
    <path d="M28 155C20 150 12 153 6 158" opacity=".25"/><ellipse cx="6" cy="158" rx="10" ry="14" transform="rotate(15,6,158)" opacity=".12"/>
    <path d="M32 110C40 105 48 108 54 104" opacity=".25"/><ellipse cx="54" cy="104" rx="10" ry="14" transform="rotate(-10,54,104)" opacity=".12"/>
    <path d="M28 70C18 68 12 72 8 78" opacity=".2"/><ellipse cx="8" cy="78" rx="8" ry="12" transform="rotate(20,8,78)" opacity=".1"/>
    <path d="M32 40C40 36 48 38 54 34" opacity=".15"/><ellipse cx="54" cy="34" rx="7" ry="10" transform="rotate(-15,54,34)" opacity=".08"/>
    <circle cx="30" cy="140" r="1.5" opacity=".2"/><circle cx="30" cy="80" r="1.5" opacity=".15"/>
  </svg></div>
  <div class="hero-content">
    <!-- S3: Hero breathing seed — signature moment -->
    <div class="hero-seed" aria-hidden="true">
      <span class="hero-seed-halo"></span>
      <span class="hero-seed-halo hero-seed-halo--2"></span>
      <span class="hero-seed-core"></span>
    </div>
    <div class="hero-eyebrow"><span class="seed-dot seed-dot--ring" aria-hidden="true" style="margin-right:10px"></span>RECOVER GANGNAM · SKIN RECOVERY DESIGN</div>
    <!-- PERSONA TOGGLE -->
    <div class="persona-toggle" role="tablist" aria-label="접근 방식 선택">
      <button class="pt-btn active" data-persona="gentle" role="tab" aria-selected="true">
        <span class="pt-dot" aria-hidden="true"></span>
        <span class="pt-k">섬세한 회복</span>
        <span class="pt-sub">Gentle</span>
      </button>
      <button class="pt-btn" data-persona="focused" role="tab" aria-selected="false">
        <span class="pt-dot" aria-hidden="true"></span>
        <span class="pt-k">집중적 개선</span>
        <span class="pt-sub">Focused</span>
      </button>
    </div>
    <div class="hero-brand-row">
      <div class="hero-brand-emblem"><img class="hero-emblem" src="/logo/R_emblem_original.png" alt="R"></div>
      <h2 class="hero-brand">E:COVER<span>한 의 원</span></h2>
    </div>
    <div class="hero-gold-line"></div>
    <h1 class="hero-headline" data-gentle="피부 아래의 원리까지 읽고<br><em>회복의 조건</em>을 봅니다" data-focused="흉터의 표면보다<br><em>회복이 멈춘 이유</em>를 봅니다">피부 아래의 원리까지 읽고<br><em>회복의 조건</em>을 봅니다</h1>
    <p class="hero-sub-copy" data-gentle="리커버한의원 강남은 AI 피부 분석과 한의학 기반 회복 관점으로<br>피부의 결, 흔적, 생활 리듬을 읽고<br>회복의 조건과 순서를 정리합니다." data-focused="패인 흉터와 자국을 피부 아래 구조까지 살펴<br>필요한 자극, 회복 간격, 기록의 기준을<br>차분하게 정리합니다.">리커버한의원 강남은 AI 피부 분석과 한의학 기반 회복 관점으로<br>피부의 결, 흔적, 생활 리듬을 읽고<br>회복의 조건과 순서를 정리합니다.</p>
    <div class="hero-actions">
      <a href="#consult" class="btn-primary" data-gentle-label="BASELINE 상담 시작" data-focused-label="흉터 회복 기준 상담"><span>BASELINE 상담 시작</span><span class="arr"></span></a>
      <a href="#values" class="btn-ghost" data-gentle-label="리커버 방식 보기" data-focused-label="회복 기준 보기">리커버 방식 보기<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M19 12l-7 7-7-7"/></svg></a>
    </div>
    <p class="hero-cta-sub">선릉역 7번 출구 앞 5층 · <strong>2026.08.17 강남 개원</strong> · 프리오픈 상담 진행 중</p>

    <!-- HERO DATA STRIP — 4칩 측정·자격 시그널 (Phase 1-C) -->
    <div class="hero-data-strip" aria-label="진료 데이터 요약">
      <div class="hd-chip">
        <svg class="hd-chip-ic" viewBox="0 0 16 16" fill="none" stroke="currentColor"><path d="M2 8l3 3 5-6M9 12l3-3"/></svg>
        <span class="hd-chip-lbl">첫 상담</span>
        <span class="hd-chip-val"><span class="num">BASELINE</span></span>
        <span class="hd-chip-sub">회복 조건을 먼저 정리</span>
      </div>
      <div class="hd-chip">
        <svg class="hd-chip-ic" viewBox="0 0 16 16" fill="none" stroke="currentColor"><rect x="2" y="3" width="12" height="10" rx="1"/><path d="M2 6h12M5 9h2M5 11h4"/></svg>
        <span class="hd-chip-lbl">분석</span>
        <span class="hd-chip-val"><span class="num">RECOVER&nbsp;AI</span></span>
        <span class="hd-chip-sub">피부 신호와 변화 기록</span>
      </div>
      <div class="hd-chip">
        <svg class="hd-chip-ic" viewBox="0 0 16 16" fill="none" stroke="currentColor"><path d="M3 13L13 3M3 3l10 10"/><circle cx="8" cy="8" r="6.5" stroke-dasharray="2 1.5"/></svg>
        <span class="hd-chip-lbl">흉터</span>
        <span class="hd-chip-val"><span class="num">ANATOMY</span></span>
        <span class="hd-chip-sub">피부 아래 구조 시각화</span>
      </div>
      <div class="hd-chip">
        <svg class="hd-chip-ic" viewBox="0 0 16 16" fill="none" stroke="currentColor"><path d="M2 14L6 9l3 2 5-7"/><path d="M11 4h3v3"/></svg>
        <span class="hd-chip-lbl">설계</span>
        <span class="hd-chip-val"><span class="num">RECORD</span></span>
        <span class="hd-chip-sub">다음 회복 순서 조정</span>
      </div>
    </div>

    <div class="hero-trust">
      <div class="ht-item">
        <span class="ht-stars" aria-hidden="true">BASELINE</span>
        <span class="ht-val"><strong>첫 기준</strong></span>
        <span class="ht-k">상담 후 정리</span>
      </div>
      <span class="ht-sep" aria-hidden="true"></span>
      <div class="ht-item">
        <span class="ht-dot" aria-hidden="true"></span>
        <span class="ht-val"><strong>프리오픈</strong></span>
        <span class="ht-k">상담 우선 안내</span>
      </div>
      <span class="ht-sep" aria-hidden="true"></span>
      <div class="ht-item">
        <svg class="ht-ic" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M8 14s-5-4-5-8a5 5 0 0110 0c0 4-5 8-5 8z"/><circle cx="8" cy="6" r="1.7"/></svg>
        <span class="ht-val"><strong>선릉역</strong></span>
        <span class="ht-k">7번 출구 도보 1분</span>
      </div>
    </div>
  </div>
  <div class="hero-scroll"><span>SCROLL</span><span class="hero-scroll-line"></span></div>
</section>

<!-- ━━━ HERO ANATOMY FILM — 새살침 시술 영상 (Phase H) ━━━ -->
<section class="hero-film" aria-label="새살침 시술 해부학 영상">
  <div class="hero-film-inner">
    <div class="hero-film-cap">
      <span class="hero-film-eye">RECOVER ANATOMY · Visual Field</span>
      <h2 class="hero-film-title">섬유 유착을 끊고,<br/><em>콜라겐을 다시 짜다</em></h2>
      <p class="hero-film-sub">새살침이 진피의 섬유 유착을 풀어 <strong style="color:var(--gold-light);font-weight:500">차오를 공간</strong>을 만들고, 그 자리에서 콜라겐이 재구성되는 환경을 정돈합니다. 표피의 자극이 아니라 진피 안 <strong style="color:var(--gold-light);font-weight:500">구조의 변화</strong>입니다.</p>
      <div class="hero-film-meta">
        <span><strong>FILM</strong> · 새살침 시술 시퀀스</span>
        <span class="vsep">·</span>
        <span><strong>DEPTH</strong> · 진피 0.8 – 1.5 mm</span>
        <span class="vsep">·</span>
        <span><strong>STAGE</strong> · in-clinic observation</span>
      </div>
    </div>
    <div class="hero-film-stage">
      <video class="hero-film-video"
             src="/video/saesalchim_graded.mp4"
             autoplay muted loop playsinline
             preload="metadata"
             poster="/logo/R_emblem_original.png"
             aria-label="새살침 시술 영상 — 무음 자동 재생, 임상 효능 미주장"></video>
      <div class="hero-film-overlay" aria-hidden="true">
        <div class="hero-film-corner tl"></div>
        <div class="hero-film-corner tr"></div>
        <div class="hero-film-corner bl"></div>
        <div class="hero-film-corner br"></div>
      </div>
      <div class="hero-film-stamp">
        <span class="hero-film-stamp-dot"></span>
        <span class="hero-film-stamp-txt">RECOVER · ANATOMY · LIVE</span>
      </div>
      <div class="hero-film-counter">REEL 01 / 04</div>
    </div>
  </div>
  <p class="hero-film-disclaimer">* 본 영상은 실제 시술 영상이며 임상 효능을 보장하지 않습니다. 회복 속도와 결과는 개인의 피부 상태에 따라 달라집니다.</p>
</section>

<!-- GUARANTEE STRIP — 리스크 해소 배너 -->
<section class="guarantee-strip" aria-label="상담 안내">
  <div class="gs-inner">
    <div class="gs-item">
      <svg class="gs-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2L4 6v6c0 5 3.5 8.5 8 10 4.5-1.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/></svg>
      <div class="gs-body"><strong>RECOVER BASELINE</strong><span>첫 상담에서 회복 기준을 정리합니다</span></div>
    </div>
    <span class="gs-sep" aria-hidden="true"></span>
    <div class="gs-item">
      <svg class="gs-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 12a9 9 0 0118 0"/><path d="M3 12a9 9 0 0018 0"/><path d="M3 12h4M17 12h4"/></svg>
      <div class="gs-body"><strong>선릉역 7번 출구 앞</strong><span>5층에서 시작하는 리커버 강남</span></div>
    </div>
    <span class="gs-sep" aria-hidden="true"></span>
    <div class="gs-item">
      <svg class="gs-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 8v4l3 2"/><circle cx="12" cy="12" r="9"/></svg>
      <div class="gs-body"><strong>흉터 원리 설명</strong><span>피부 아래 구조를 보이게 설명합니다</span></div>
    </div>
    <span class="gs-sep" aria-hidden="true"></span>
    <a class="gs-item gs-link" href="#treatments">
      <svg class="gs-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="5" width="18" height="14" rx="1.5"/><path d="M3 9h18M7 13h3M7 16h5"/></svg>
      <div class="gs-body"><strong>상담 후 기준 정리 <span class="gs-chev">→</span></strong><span>할 것과 미룰 것을 함께 구분합니다</span></div>
    </a>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════
   RESULT SLICE — 히어로 직후 "결과·돈·시간" 픽업존
   20대·실용주의 남성·임원층이 0.5스크롤에서 답을 얻고
   감성 서사로 진입할 결정 기준을 갖게 함
   ═══════════════════════════════════════════════════════════ -->
<section class="result-slice" id="result-slice" aria-label="시술 결과 · 가격 · 시간 미리보기" data-screen-label="01b Result Slice">
  <div class="rs-inner">
    <header class="rs-head rv">
      <p class="rs-eyebrow"><span class="rs-eyebrow-line"></span>At a Glance<span class="rs-eyebrow-line"></span></p>
      <h2 class="rs-title">회복을 정하기 전<br/><em>세 가지를 먼저 봅니다</em></h2>
      <p class="rs-sub">피부 신호 · 아래 구조 · 회복 순서. 결과보다 먼저, 필요한 기준을 정리합니다.</p>
    </header>

    <!-- 결과 4장 (성별 균형: 여3 남1 + 토글로 남성 우선 모드) -->
    <div class="rs-results rv rv-d1">
      <div class="rs-results-head">
        <span class="rs-mini-label"><span class="rs-mini-dot"></span>최근 진료 사례</span>
        <div class="rs-results-toggle" role="tablist" aria-label="결과 필터">
          <button class="rs-rt active" data-rs-filter="all" role="tab" aria-selected="true">전체</button>
          <button class="rs-rt" data-rs-filter="male" role="tab" aria-selected="false">남성</button>
          <button class="rs-rt" data-rs-filter="female" role="tab" aria-selected="false">여성</button>
        </div>
      </div>
      <div class="rs-results-grid">
        <a href="#gallery" class="rs-rcard" data-rs-gender="female" data-rs-age="20">
          <div class="rs-rimg"><img src="/assets/ba_skin_new_1.webp" alt="만성 여드름·붉은기 8주 호전" loading="lazy"></div>
          <div class="rs-rmeta">
            <span class="rs-rtag">여드름·붉은기</span>
            <span class="rs-rdur">8주</span>
          </div>
          <p class="rs-rprofile">20대 여성 · 대학생</p>
        </a>
        <a href="#gallery" class="rs-rcard" data-rs-gender="male" data-rs-age="30">
          <div class="rs-rimg"><img src="/assets/ba_10.webp" alt="박스형 흉터 12주 개선" loading="lazy"></div>
          <div class="rs-rmeta">
            <span class="rs-rtag">흉터·자국</span>
            <span class="rs-rdur">12주</span>
          </div>
          <p class="rs-rprofile">30대 남성 · 직장인</p>
        </a>
        <a href="#gallery" class="rs-rcard" data-rs-gender="female" data-rs-age="40">
          <div class="rs-rimg"><img src="/assets/ba_skin_wrinkle_k.webp" alt="팔자주름 16주 개선" loading="lazy"></div>
          <div class="rs-rmeta">
            <span class="rs-rtag">주름·탄력</span>
            <span class="rs-rdur">16주</span>
          </div>
          <p class="rs-rprofile">40대 여성 · 교사</p>
        </a>
        <a href="#gallery" class="rs-rcard" data-rs-gender="female" data-rs-age="50">
          <div class="rs-rimg"><img src="/assets/ba_skin_lifting_k.webp" alt="턱선 리프팅 12주" loading="lazy"></div>
          <div class="rs-rmeta">
            <span class="rs-rtag">리프팅</span>
            <span class="rs-rdur">12주</span>
          </div>
          <p class="rs-rprofile">50대 여성 · 주부</p>
        </a>
      </div>
      <a href="#gallery" class="rs-results-more">전체 12개 사례 자세히 보기 <span aria-hidden="true">→</span></a>
    </div>

    <!-- 가격 레인지 3카드 -->
    <div class="rs-prices rv rv-d2">
      <span class="rs-mini-label"><span class="rs-mini-dot"></span>가격 · 기간 가이드</span>
      <div class="rs-prices-grid">
        <a href="#treatments" class="rs-pcard">
          <div class="rs-pcard-head">
            <span class="rs-pcard-num">A</span>
            <span class="rs-pcard-cat">여드름 자국 · 모공 · 표면 결</span>
          </div>
          <div class="rs-pcard-price">
            <span class="rs-pcard-from">From</span>
            <strong>15만원~</strong>
            <span class="rs-pcard-unit">/ 회차당</span>
          </div>
          <div class="rs-pcard-meta">
            <span><span class="rs-pcard-meta-k">권장 기간</span><span class="rs-pcard-meta-v">8~12주</span></span>
            <span><span class="rs-pcard-meta-k">방문 간격</span><span class="rs-pcard-meta-v">주 1~2회</span></span>
            <span><span class="rs-pcard-meta-k">다운타임</span><span class="rs-pcard-meta-v">없음</span></span>
          </div>
          <span class="rs-pcard-link">상세 보기 →</span>
        </a>
        <a href="#treatments" class="rs-pcard rs-pcard--feat">
          <div class="rs-pcard-head">
            <span class="rs-pcard-num">B</span>
            <span class="rs-pcard-cat">패인 흉터 · 심부 흉터 회복</span>
          </div>
          <div class="rs-pcard-price">
            <span class="rs-pcard-from">From</span>
            <strong>30만원~</strong>
            <span class="rs-pcard-unit">/ 회차당</span>
          </div>
          <div class="rs-pcard-meta">
            <span><span class="rs-pcard-meta-k">권장 기간</span><span class="rs-pcard-meta-v">12~16주</span></span>
            <span><span class="rs-pcard-meta-k">방문 간격</span><span class="rs-pcard-meta-v">주 1회</span></span>
            <span><span class="rs-pcard-meta-k">다운타임</span><span class="rs-pcard-meta-v">반나절</span></span>
