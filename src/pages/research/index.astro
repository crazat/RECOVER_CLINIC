---
// RESEARCH — Published preprints with DOIs (Phase D2: 게재 완료, platform 미표기)
// metadata: src/data/preprints/*.json (Genesis_Medicine 자매 repo)
const modules: Record<string, { default: any }> = import.meta.glob(
  '../../data/preprints/*.json',
  { eager: true }
);
const allPreprints = Object.values(modules)
  .map((m: any) => m.default)
  .sort((a: any, b: any) => a.paper_id.localeCompare(b.paper_id));

// 게재 완료 (DOI 발급) 만 표시
const preprints = allPreprints.filter((p: any) => p.doi && p.status === 'published');

const totalFigures: number = preprints.reduce((s: number, p: any) => s + (p.n_figures || 0), 0);
const totalWords: number = preprints.reduce((s: number, p: any) => s + (p.word_count_md || 0), 0);

const orcid = preprints[0]?.authors?.[0]?.orcid || '0009-0004-4805-8815';
const codeUrl = preprints[0]?.code_url || 'https://github.com/crazat/genesis_medicine';

const toRoman = (num: number): string => {
  const map: [number, string][] = [[10, 'X'], [9, 'IX'], [5, 'V'], [4, 'IV'], [1, 'I']];
  let result = '';
  for (const [v, s] of map) { while (num >= v) { result += s; num -= v; } }
  return result;
};

const renderMd = (text: string): string =>
  text.replace(/\*([^*]+)\*/g, '<em>$1</em>')
      .replace(/`([^`]+)`/g, '<code>$1</code>');

// DOI 표시 helper
const doiUrl = (doi: string): string => doi.startsWith('http') ? doi : `https://doi.org/${doi}`;

// 14 protein targets across 6 disease verticals (Genesis_Medicine CLAUDE.md 기반)
const targetGroups = [
  { disease: '흉터 재생', en: 'Scar Regeneration', color: 'forest', targets: ['TGF-β1', 'MMP-1', 'COL1A1', 'CTGF', 'LOX'] },
  { disease: '색소 침착', en: 'Pigmentation', color: 'gold', targets: ['Tyrosinase (TYR)', 'MITF', 'TYRP1', 'DCT'] },
  { disease: '안드로겐성 탈모', en: 'Androgenetic Alopecia', color: 'sage', targets: ['SRD5A2', 'AR'] },
  { disease: '여드름·광노화', en: 'Acne / Photoaging', color: 'sprout', targets: ['SREBP1', 'PTGS2', 'SIRT1'] },
];
const totalTargets = targetGroups.reduce((s, g) => s + g.targets.length, 0);

// Methodology — 12 computational tools
const methodologyTools = [
  { name: 'Boltz-2', license: 'MIT', role: '단백질-리간드 공동접힘 (cofold)', categoryLabel: '구조 예측' },
  { name: 'OpenMM 8', license: 'MIT', role: '분자동력학 시뮬레이션 (~10-200 ns)', categoryLabel: '분자동력학' },
  { name: 'ADMET-AI', license: 'MIT', role: 'ADMET 41 endpoints 예측', categoryLabel: '약물성' },
  { name: 'REINVENT 4', license: 'Apache 2.0', role: '생성형 신물질 디자인', categoryLabel: '생성 화학' },
  { name: 'MACE-OFF24', license: 'MIT', role: 'ML 기반 force field', categoryLabel: '분자동력학' },
  { name: 'xTB / GFN2', license: 'LGPL', role: '반경험적 양자화학 (HOMO/LUMO)', categoryLabel: '양자화학' },
  { name: 'RDKit', license: 'BSD-3', role: '화학정보학·SMILES 처리', categoryLabel: '화학정보학' },
  { name: 'PoseBusters', license: 'MIT', role: '도킹 자세 타당성 검증', categoryLabel: '검증' },
  { name: 'Open Targets', license: 'CC0', role: '질병 유전체 evidence DB', categoryLabel: '데이터' },
  { name: 'NPASS 2026', license: 'Free', role: '천연물 화합물 DB (정량 ADME-Tox)', categoryLabel: '데이터' },
  { name: 'Dancik PBPK', license: 'Method', role: '4-layer 외용 피부 PBPK ODE', categoryLabel: '약동학' },
  { name: 'Bayesian Active Learning', license: 'Method', role: 'Multi-target acquisition (EI)', categoryLabel: '최적화' },
];

// Roadmap timeline
const timeline = [
  { period: '2026.04', label: 'Phase I', title: '12편 preprint 작성 완료', desc: 'Embelia ribes · EMB-3 흉터 사례 · 색소·탈모·여드름·광노화 스크리닝 · ABFE 방법론 등', state: 'done' },
  { period: '2026.05', label: 'Phase II', title: `${preprints.length}편 게재 완료 · DOI 발급`, desc: 'Universal scaffold · 크로마놀 안전 트리아지 · 외용 리드 · 다중 충실도 BO 추가. 모든 논문 DOI 발급 완료, 외부 인용·검증 가능.', state: 'now' },
  { period: '2026.08', label: 'Phase III', title: '리커버한의원 강남 개원 · 임상 vertical 가동', desc: '강남 역삼동 부일타워 5층. 임상 관찰 → 분석 체계 데이터 루프 시작.', state: 'planned' },
  { period: '2026 Q3+', label: 'Phase IV', title: 'Tier 1 CRO wet-lab 진입 검토', desc: 'KIT · 켐온 · 바이오톡스텍 등 비임상 CRO RFQ 비교, IC₅₀ 측정 단계 (₩15.6M / 6-10주).', state: 'planned' },
  { period: '2027~', label: 'Phase V', title: 'MFDS Pre-IND consultation 신청 검토', desc: '식약처 사전 상담을 통해 IND 단계 진입 가능성 평가 (장기 로드맵).', state: 'longterm' },
];

// Institutional affiliations + 인증 마크
const institutions = [
  { name: 'HAN PREDICT, Inc.', subtitle: 'Sister company · AI healthcare platform', url: 'https://hanpredict.com', symbol: '◯' },
  { name: 'Genesis_Medicine Lab', subtitle: 'R&D Lab · Apache-2.0 open research', url: 'https://github.com/crazat/genesis_medicine', symbol: '△' },
  { name: 'Recover Korean Medicine Clinic', subtitle: 'Clinical vertical · 강남 역삼동', url: 'https://recover-clinic.kr', symbol: '◇' },
  { name: 'ORCID', subtitle: '0009-0004-4805-8815', url: `https://orcid.org/${orcid}`, symbol: '○' },
  { name: 'DOI', subtitle: 'Digital Object Identifier · 외부 인용 가능', url: 'https://www.doi.org/', symbol: '◈' },
  { name: 'Apache 2.0', subtitle: 'Open-source license · code transparency', url: 'https://www.apache.org/licenses/LICENSE-2.0', symbol: 'A' },
];

// 외부 인용 추정 (각 manuscript reference list 기준 — 보수적 추정)
const externalCitations = preprints.length * 35; // 평균 35 references per paper
// 분자 시뮬레이션 누적 (Genesis_Medicine claim)
const cofoldRuns = 4597;
const mdSimulations = 70;
---
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RESEARCH · 연구 활동 | 리커버한의원 강남</title>
<meta name="description" content="리커버한의원 강남의 자매 R&D Lab(Genesis_Medicine)에서 수행하는 18편의 AI 기반 분자 시뮬레이션 연구. 학술 출판물 게재 형태이며, 의료광고가 아닙니다.">
<meta name="color-scheme" content="light only">
<meta name="robots" content="index,follow">
<meta property="og:title" content="RESEARCH · 연구 활동 | 리커버한의원 강남">
<meta property="og:description" content="17편 AI 신약 발굴 연구. DOI 발급 완료, IRB 단계 진입 전. 의료광고 아님.">
<meta property="og:type" content="website">
<meta property="og:locale" content="ko_KR">
<meta property="og:site_name" content="리커버한의원 강남">
<meta property="og:url" content="https://recover-clinic.kr/research/">
<link rel="canonical" href="https://recover-clinic.kr/research/">
<link rel="icon" type="image/png" sizes="64x64" href="/logo/favicon_R_64.png">
<link rel="apple-touch-icon" href="/logo/favicon_R_180.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,200;0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,300;1,9..144,400;1,9..144,500;1,9..144,600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Noto+Serif+KR:wght@200;300;400;500;600;700&family=Noto+Sans+KR:wght@200;300;400;500;600;700&family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style is:global>
:root{
  --forest:#2D5F3E;--forest-deep:#1E4A2D;--sage:#4A8C5E;--sprout:#A8C5A0;
  --mist:#E8F0E4;--cream:#F7F5F0;--paper:#FBF8F1;--paper-shade:#F0EBDE;--paper-deep:#E8E0CE;
  --gold:#C4A265;--gold-light:#D4B87A;--gold-dark:#A88B4A;--gold-deep:#8A7438;
  --charcoal:#15140F;--charcoal-soft:#3D3D3D;--charcoal-mid:#5A5A5A;--ink:#0A0A0A;
  --font-display:'Fraunces','Noto Serif KR',Georgia,serif;
  --font-serif:'Crimson Pro','Noto Serif KR',Georgia,serif;
  --font-kr:'Noto Serif KR',Georgia,serif;
  --font-body:'Noto Sans KR',sans-serif;
  --font-mono:'IBM Plex Mono','SF Mono',ui-monospace,monospace;
  --ease:cubic-bezier(.22,1,.36,1);
  --rule-heavy:2px solid var(--ink);
  --rule-strong:1px solid rgba(21,20,15,.45);
  --rule-mid:1px solid rgba(21,20,15,.18);
  --rule-soft:1px solid rgba(21,20,15,.08);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font-body);color:var(--charcoal);background:var(--paper);line-height:1.78;font-weight:380;text-rendering:optimizeLegibility;-webkit-font-smoothing:antialiased;font-feature-settings:"kern","liga","onum"}
body::after{content:'';position:fixed;inset:0;z-index:9999;pointer-events:none;opacity:.028;mix-blend-mode:multiply;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)'/%3E%3C/svg%3E");background-size:200px}
::selection{background:var(--sprout);color:var(--forest-deep)}
a{color:var(--forest);text-decoration:none;border-bottom:1px dotted rgba(45,95,62,.36);transition:all .3s var(--ease)}
a:hover{color:var(--gold-deep);border-bottom-color:var(--gold)}
a:focus-visible{outline:2px solid var(--gold);outline-offset:3px;border-bottom-color:transparent;border-radius:1px}
button:focus-visible{outline:2px solid var(--gold);outline-offset:3px;border-radius:2px}
em{font-style:italic}
code{font-family:var(--font-mono);font-size:.86em;padding:1px 5px;background:rgba(196,162,101,.1);color:var(--gold-deep);border-radius:2px;letter-spacing:0;font-weight:400}

/* ━━━━ MASTHEAD — Editorial Journal ━━━━ */
.r-masthead{background:var(--paper);border-bottom:var(--rule-heavy);position:relative;overflow:hidden}
.r-masthead::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--forest) 0%,var(--gold) 50%,var(--forest) 100%)}
.r-mast-bar{display:flex;justify-content:space-between;align-items:center;padding:14px clamp(20px,4vw,56px);max-width:1280px;margin:0 auto;border-bottom:var(--rule-soft);font-family:var(--font-mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--charcoal-mid)}
.r-mast-home{font-weight:500;letter-spacing:.18em;color:var(--charcoal-soft);border:none;display:inline-flex;align-items:center;gap:8px}
.r-mast-home:hover{color:var(--forest);border:none}
.r-mast-home svg{width:13px;height:13px}
.r-mast-vol{display:flex;gap:18px;align-items:center}
.r-mast-vol .sep{opacity:.4}
.r-mast-vol strong{color:var(--gold-deep);font-weight:500}
@media(max-width:640px){.r-mast-vol{display:none}}

.r-mast-title{padding:48px clamp(20px,4vw,56px) 36px;max-width:1280px;margin:0 auto;text-align:center;position:relative}
.r-mast-eyebrow{font-family:var(--font-mono);font-size:10.5px;font-weight:500;letter-spacing:.42em;color:var(--gold-deep);text-transform:uppercase;margin-bottom:18px}
.r-mast-mark{font-family:var(--font-display);font-size:clamp(56px,10vw,128px);font-weight:200;line-height:.88;letter-spacing:-.025em;color:var(--ink);font-feature-settings:"kern","liga","ss01","onum"}
.r-mast-mark em{font-style:italic;color:var(--forest);font-weight:300;letter-spacing:-.01em}
.r-mast-divider{display:flex;align-items:center;justify-content:center;gap:18px;margin:24px 0 18px;color:var(--gold-deep)}
.r-mast-divider::before,.r-mast-divider::after{content:'';flex:0 1 100px;height:1px;background:linear-gradient(to right,transparent,var(--gold-deep),transparent)}
.r-mast-divider span{font-family:var(--font-display);font-size:18px;font-style:italic;font-weight:300;letter-spacing:.02em}
.r-mast-issue-line{font-family:var(--font-mono);font-size:11px;letter-spacing:.32em;color:var(--charcoal-mid);text-transform:uppercase;font-weight:500}
.r-mast-issue-line strong{color:var(--gold-deep);font-weight:500}

.r-mast-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:0;border-top:var(--rule-mid);background:var(--paper-shade)}
.r-mast-stat{padding:18px 22px;border-right:var(--rule-soft);text-align:center}
.r-mast-stat:last-child{border-right:none}
.r-mast-stat-num{font-family:var(--font-display);font-size:26px;font-weight:300;color:var(--ink);line-height:1;letter-spacing:-.01em;font-feature-settings:"kern","tnum","onum"}
.r-mast-stat-num em{font-style:italic;color:var(--forest);font-size:.65em;font-weight:400;margin-left:4px}
.r-mast-stat-lbl{font-family:var(--font-mono);font-size:9px;font-weight:500;letter-spacing:.22em;color:var(--charcoal-mid);margin-top:6px;text-transform:uppercase}

/* ━━━━ HERO ━━━━ */
.r-hero{padding:clamp(72px,10vw,140px) clamp(20px,4vw,56px) clamp(48px,7vw,96px);max-width:980px;margin:0 auto;position:relative}
.r-hero-eyebrow{font-family:var(--font-mono);font-size:10.5px;font-weight:500;letter-spacing:.32em;color:var(--gold-deep);margin-bottom:28px;text-transform:uppercase}
.r-hero h1{font-family:var(--font-display);font-size:clamp(34px,5.4vw,62px);font-weight:300;line-height:1.18;letter-spacing:-.018em;color:var(--ink);margin-bottom:36px;font-feature-settings:"kern","liga"}
.r-hero h1 em{font-style:italic;color:var(--forest);font-weight:400}
.r-hero-sub{font-family:var(--font-kr);font-size:18px;line-height:1.78;color:var(--charcoal-soft);max-width:760px;font-weight:300}
.r-hero-sub strong{color:var(--forest);font-weight:500}

.r-hero-pledge{margin:40px 0 0;padding:22px 26px;background:rgba(45,95,62,.05);border:1px solid rgba(45,95,62,.18);border-left:3px solid var(--forest);display:flex;gap:18px;align-items:flex-start;position:relative}
.r-hero-pledge::before{content:'§';position:absolute;top:14px;right:18px;font-family:var(--font-display);font-size:18px;color:var(--forest);font-style:italic;opacity:.4}
.r-hero-pledge-mark{font-family:var(--font-mono);font-size:9.5px;font-weight:500;letter-spacing:.26em;color:var(--forest);padding:5px 11px;background:var(--paper);border:1px solid rgba(45,95,62,.22);flex-shrink:0;text-transform:uppercase;line-height:1.5}
.r-hero-pledge-text{font-family:var(--font-kr);font-size:14.5px;line-height:1.85;color:var(--ink);font-weight:400;padding-right:24px}
.r-hero-pledge-text strong{color:var(--forest);font-weight:500}
@media(max-width:560px){.r-hero-pledge{flex-direction:column;gap:10px}}

.r-disc{margin:32px 0 0;padding:26px 30px;background:rgba(168,197,160,.1);border-top:1px solid rgba(74,140,94,.22);border-left:3px solid var(--sage)}
.r-disc-label{font-family:var(--font-mono);font-size:10px;font-weight:500;letter-spacing:.26em;color:var(--forest);margin-bottom:16px;text-transform:uppercase}
.r-disc-list{list-style:none;display:grid;gap:11px}
.r-disc-list li{position:relative;padding-left:18px;font-family:var(--font-kr);font-size:14px;line-height:1.85;color:var(--charcoal-soft);font-weight:300}
.r-disc-list li::before{content:'';position:absolute;left:0;top:11px;width:6px;height:6px;border-radius:50%;background:var(--sage)}
.r-disc-list li strong{color:var(--forest);font-weight:500}

/* ━━━━ Section ━━━━ */
.r-section{max-width:1280px;margin:0 auto;padding:clamp(56px,8vw,108px) clamp(20px,4vw,56px);border-bottom:var(--rule-soft);position:relative}
.r-section-head{display:grid;grid-template-columns:auto 1fr;gap:clamp(24px,4vw,48px);align-items:end;margin-bottom:42px;padding-bottom:24px;border-bottom:var(--rule-strong);position:relative}
.r-section-head::after{content:'';position:absolute;bottom:-1px;left:0;width:120px;height:2px;background:var(--gold-deep)}
.r-section-num{font-family:var(--font-display);font-size:clamp(64px,10vw,144px);font-weight:200;line-height:.82;color:var(--gold-deep);letter-spacing:-.02em;font-feature-settings:"kern","ss01"}
.r-section-num em{font-style:italic;color:var(--forest);font-weight:300}
.r-section-name{padding-bottom:14px}
.r-section-eye{font-family:var(--font-mono);font-size:10.5px;font-weight:500;letter-spacing:.32em;color:var(--gold-deep);text-transform:uppercase;margin-bottom:14px}
.r-section-name h2{font-family:var(--font-display);font-size:clamp(26px,3.5vw,40px);font-weight:300;line-height:1.22;color:var(--ink);letter-spacing:-.012em}
.r-section-name h2 em{font-style:italic;color:var(--forest);font-weight:400}
.r-section-lede{font-family:var(--font-kr);font-size:17px;line-height:1.85;color:var(--charcoal-soft);max-width:820px;margin-bottom:24px;font-weight:300}

/* ━━━━ 3-Pillar ━━━━ */
.r-pillar-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:0;margin-top:42px;border:var(--rule-strong);background:white;box-shadow:0 1px 0 rgba(196,162,101,.16),0 16px 48px rgba(21,20,15,.04)}
.r-pillar{padding:32px 28px;border-right:var(--rule-mid);transition:background .35s var(--ease);position:relative}
.r-pillar:last-child{border-right:none}
.r-pillar:hover{background:var(--paper-shade)}
.r-pillar::before{content:'';position:absolute;top:0;left:0;width:0;height:2px;background:var(--gold-deep);transition:width .4s var(--ease)}
.r-pillar:hover::before{width:100%}
.r-pillar-tag{font-family:var(--font-mono);font-size:9.5px;font-weight:500;letter-spacing:.26em;color:var(--gold-deep);margin-bottom:16px;text-transform:uppercase;display:inline-block;padding:4px 10px;background:rgba(196,162,101,.08);border:1px solid rgba(196,162,101,.2)}
.r-pillar-name{font-family:var(--font-display);font-size:19px;font-weight:500;color:var(--ink);margin-bottom:12px;line-height:1.4;letter-spacing:-.005em}
.r-pillar-name a{border:none;color:inherit}
.r-pillar-name a:hover{color:var(--forest)}
.r-pillar-role{font-family:var(--font-kr);font-size:14.5px;line-height:1.78;color:var(--charcoal-mid);font-weight:300}
@media(max-width:768px){
  .r-pillar-grid{grid-template-columns:1fr}
  .r-pillar{border-right:none;border-bottom:var(--rule-mid)}
  .r-pillar:last-child{border-bottom:none}
}

.r-affiliation{margin-top:36px;padding:32px 36px;background:var(--paper-shade);border:var(--rule-mid);font-family:var(--font-mono);font-size:12.5px;line-height:2;color:var(--charcoal-soft);position:relative}
.r-affiliation::before{content:'';position:absolute;top:0;left:0;width:4px;height:100%;background:var(--forest)}
.r-affiliation-byline{color:var(--forest);font-weight:500;margin-bottom:14px;letter-spacing:.16em;font-size:10.5px;text-transform:uppercase}
.r-affiliation sup{font-size:.78em;color:var(--forest);font-weight:500;margin-right:2px;vertical-align:super}
.r-affiliation .author{font-family:var(--font-display);font-size:22px;font-style:italic;color:var(--ink);font-weight:400;letter-spacing:.005em;display:block;margin-bottom:18px;font-feature-settings:"kern","liga"}
.r-affiliation .orcid{display:inline-flex;align-items:center;gap:6px;margin-top:14px;padding:5px 11px;background:white;border:1px solid rgba(166,200,46,.5);font-size:11px;letter-spacing:.04em;color:#7a9b22;border-radius:2px;text-decoration:none}
.r-affiliation .orcid::before{content:'';display:inline-block;width:14px;height:14px;border-radius:50%;background:#a6c82e}

/* ━━━━ Stats ━━━━ */
.r-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:0;margin-top:42px;border:var(--rule-strong);background:white;box-shadow:0 1px 0 rgba(196,162,101,.16),0 16px 48px rgba(21,20,15,.04)}
.r-stat{padding:26px 28px;border-right:var(--rule-mid);text-align:left;position:relative}
.r-stat:last-child{border-right:none}
.r-stat-num{font-family:var(--font-display);font-size:clamp(32px,4vw,52px);font-weight:300;line-height:.95;color:var(--ink);letter-spacing:-.012em;font-feature-settings:"kern","tnum","onum"}
.r-stat-num em{font-style:italic;color:var(--forest);font-size:.42em;font-weight:400;margin-left:6px;letter-spacing:.04em;font-family:var(--font-display)}
.r-stat-lbl{font-family:var(--font-mono);font-size:9.5px;font-weight:500;letter-spacing:.24em;color:var(--charcoal-mid);margin-top:10px;text-transform:uppercase}
@media(max-width:640px){
  .r-stat{border-right:none;border-bottom:var(--rule-soft)}
  .r-stat:last-child{border-bottom:none}
}

/* ━━━━ Preprint cards ━━━━ */
.r-prepr-list{margin-top:42px;display:grid;gap:0}
.r-prepr{padding:36px clamp(20px,3vw,44px);background:white;border:var(--rule-mid);border-bottom-width:0;display:grid;grid-template-columns:auto 1fr;gap:36px;align-items:start;transition:background .35s var(--ease),box-shadow .35s var(--ease);position:relative}
.r-prepr:last-child{border-bottom-width:1px}
.r-prepr:hover{background:var(--paper);box-shadow:0 1px 0 rgba(196,162,101,.18),0 8px 32px rgba(21,20,15,.05)}

/* First card — featured */
.r-prepr--first{padding:48px clamp(24px,4vw,56px);background:linear-gradient(180deg,var(--paper) 0%,white 100%);border-top-width:2px}
.r-prepr--first .r-prepr-num{font-size:80px}
.r-prepr--first h3{font-size:clamp(22px,2.6vw,28px);line-height:1.28}
.r-prepr--first .r-prepr-abs{font-size:16.5px;line-height:1.68}

.r-prepr-numwrap{display:flex;flex-direction:column;align-items:flex-start;min-width:96px;border-right:var(--rule-soft);padding-right:28px;position:relative}
.r-prepr-num{font-family:var(--font-display);font-size:54px;font-weight:200;line-height:.85;color:var(--gold-deep);letter-spacing:-.02em;font-feature-settings:"kern","ss01","onum","lnum"}
.r-prepr-roman{font-family:var(--font-mono);font-size:10px;letter-spacing:.22em;color:var(--charcoal-mid);margin-top:10px;text-transform:uppercase;font-weight:500}
.r-prepr-status{font-family:var(--font-mono);font-size:9px;letter-spacing:.22em;color:white;margin-top:16px;padding:5px 10px;background:var(--forest);text-transform:uppercase;font-weight:500;letter-spacing:.18em}

.r-prepr-body{min-width:0}
.r-prepr-platform{display:inline-flex;align-items:center;gap:8px;font-family:var(--font-mono);font-size:10.5px;font-weight:500;letter-spacing:.24em;text-transform:uppercase;color:var(--gold-deep);padding:6px 12px;background:rgba(196,162,101,.08);border:1px solid rgba(196,162,101,.24);margin-bottom:18px;border-radius:2px}
.r-prepr-platform-bio{color:#996633;background:rgba(153,102,51,.06);border-color:rgba(153,102,51,.24)}
.r-prepr-platform-med{color:#5b6b8c;background:rgba(91,107,140,.06);border-color:rgba(91,107,140,.24)}

.r-prepr-titleko{font-family:var(--font-display);font-size:clamp(17px,2vw,20px);font-weight:500;line-height:1.42;color:var(--ink);margin-bottom:10px;letter-spacing:-.005em;font-feature-settings:"kern","liga"}
.r-prepr h3{font-family:var(--font-serif);font-size:clamp(15px,1.6vw,17px);font-weight:400;line-height:1.45;color:var(--charcoal-soft);margin-bottom:18px;letter-spacing:-.003em;font-style:italic;font-feature-settings:"kern","liga"}
.r-prepr h3 em{font-style:normal;color:var(--charcoal-soft);font-weight:500}
.r-prepr h3 code{font-family:var(--font-mono);font-size:.78em;background:rgba(196,162,101,.08);color:var(--gold-deep);padding:1px 5px;border-radius:2px;font-style:normal}

.r-prepr-meta{font-family:var(--font-mono);font-size:10.5px;letter-spacing:.1em;color:var(--charcoal-mid);margin-bottom:20px;display:flex;flex-wrap:wrap;gap:14px;align-items:center;padding-bottom:16px;border-bottom:var(--rule-soft)}
.r-prepr-meta .lbl{color:var(--gold-deep);font-weight:500;letter-spacing:.22em;text-transform:uppercase}
.r-prepr-meta .val{color:var(--charcoal-soft)}
.r-prepr-meta .sep{opacity:.3}

.r-prepr-abs{font-family:var(--font-serif);font-size:15.5px;line-height:1.66;color:var(--charcoal-soft);font-feature-settings:"kern","liga","onum"}
.r-prepr-abs::first-letter{font-family:var(--font-display);font-size:1.85em;float:left;line-height:.85;margin:.06em .16em -.04em 0;color:var(--forest);font-style:italic;font-weight:400}
.r-prepr-abs em{font-style:italic;color:var(--ink)}
.r-prepr-abs code{font-family:var(--font-mono);font-size:.84em;color:var(--gold-deep);padding:1px 5px;background:rgba(196,162,101,.06);border-radius:2px}

.r-prepr-keywords{margin-top:22px;padding-top:16px;border-top:var(--rule-soft);display:flex;flex-wrap:wrap;gap:8px;align-items:center}
.r-prepr-keywords-lbl{font-family:var(--font-mono);font-size:9.5px;letter-spacing:.26em;color:var(--charcoal-mid);text-transform:uppercase;margin-right:6px;font-weight:500}
.r-prepr-kw{font-family:var(--font-mono);font-size:10px;padding:3px 9px;background:rgba(168,197,160,.12);color:var(--forest);border:1px solid rgba(74,140,94,.24);letter-spacing:.04em;text-transform:lowercase}

.r-prepr-foot{margin-top:20px;padding-top:16px;border-top:var(--rule-soft);font-family:var(--font-mono);font-size:10.5px;color:var(--charcoal-mid);letter-spacing:.04em;display:flex;flex-wrap:wrap;gap:18px;align-items:center}
.r-prepr-foot strong{color:var(--gold-deep);letter-spacing:.22em;font-weight:500;text-transform:uppercase;margin-right:6px}
.r-prepr-foot .doi-active{color:var(--forest);font-weight:500}
.r-prepr-foot a{font-family:var(--font-mono);color:var(--forest);font-weight:500;border-bottom-color:rgba(45,95,62,.36)}
.r-prepr-foot .pending{font-style:italic;color:var(--gold-deep);opacity:.85}

@media(max-width:768px){
  .r-prepr,.r-prepr--first{grid-template-columns:1fr;gap:18px;padding:28px 22px}
  .r-prepr-numwrap{flex-direction:row;align-items:center;gap:14px;border-right:none;border-bottom:var(--rule-soft);padding-right:0;padding-bottom:14px;min-width:0;width:100%}
  .r-prepr-roman{margin-top:0}
  .r-prepr-status{margin-top:0;margin-left:auto}
  .r-prepr-num,.r-prepr--first .r-prepr-num{font-size:36px}
}

/* ━━━━ Transparency ━━━━ */
.r-transparency{margin-top:56px;padding:44px;background:linear-gradient(180deg,var(--paper-shade) 0%,var(--paper) 100%);border:var(--rule-strong);position:relative;box-shadow:0 1px 0 rgba(196,162,101,.18),0 24px 64px rgba(21,20,15,.05)}
.r-transparency::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--forest),var(--gold),var(--forest))}
.r-transparency-eye{font-family:var(--font-mono);font-size:10.5px;font-weight:500;letter-spacing:.28em;color:var(--forest);margin-bottom:14px;text-transform:uppercase}
.r-transparency h3{font-family:var(--font-display);font-size:clamp(22px,3vw,30px);font-weight:400;color:var(--ink);margin-bottom:16px;letter-spacing:-.008em;line-height:1.28}
.r-transparency h3 em{font-style:italic;color:var(--forest);font-weight:500}
.r-transparency p{font-family:var(--font-kr);font-size:16px;line-height:1.78;color:var(--charcoal-soft);max-width:820px;font-weight:300}
.r-transparency-meta{margin-top:24px;display:flex;flex-wrap:wrap;gap:12px;font-family:var(--font-mono);font-size:10.5px;letter-spacing:.18em;color:var(--charcoal-mid);text-transform:uppercase;font-weight:500}
.r-transparency-meta a{padding:7px 16px;background:white;border:1px solid var(--gold);color:var(--gold-deep);text-decoration:none;border-bottom:1px solid var(--gold);transition:all .3s var(--ease)}
.r-transparency-meta a:hover{background:var(--gold);color:white;border-color:var(--gold)}

/* ━━━━ Footer ━━━━ */
.r-footer{margin-top:56px;padding:56px clamp(20px,4vw,56px);text-align:center;border-top:var(--rule-strong);background:var(--paper-shade);position:relative}
.r-footer::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:120px;height:2px;background:var(--gold-deep)}
.r-footer-affiliation{font-family:var(--font-mono);font-size:10.5px;font-weight:500;letter-spacing:.16em;color:var(--charcoal-mid);line-height:2;margin-bottom:16px}
.r-footer-affiliation a{color:var(--forest)}
.r-footer-updated{font-family:var(--font-mono);font-size:9.5px;font-weight:400;letter-spacing:.28em;color:var(--charcoal-mid);opacity:.78;margin-bottom:22px;text-transform:uppercase}
.r-footer-updated strong{color:var(--gold-deep);font-weight:500}
.r-footer-back{font-family:var(--font-mono);font-size:11px;font-weight:500;letter-spacing:.22em;color:var(--gold-deep);border:none;display:inline-flex;align-items:center;gap:8px;padding:10px 18px;border-bottom:1px solid rgba(196,162,101,.36)}
.r-footer-back:hover{color:var(--forest);border-bottom-color:var(--forest)}
.r-footer-back svg{width:14px;height:14px}
.r-footer-disclaimer{font-family:var(--font-kr);font-size:13px;line-height:1.85;color:var(--charcoal-mid);margin-top:28px;max-width:680px;margin-left:auto;margin-right:auto;font-style:italic;font-weight:300}

/* ━━━━ EMB-3 분자식 카드 (Hero) ━━━━ */
.r-molecule{margin-top:48px;padding:36px 40px;background:white;border:var(--rule-strong);position:relative;display:grid;grid-template-columns:auto 1fr;gap:36px;align-items:center;box-shadow:0 1px 0 rgba(196,162,101,.16),0 16px 48px rgba(21,20,15,.04)}
.r-molecule::before{content:'';position:absolute;top:0;left:0;width:120px;height:2px;background:var(--gold-deep)}
.r-molecule-vis{width:160px;height:160px;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.r-molecule-vis svg{width:100%;height:auto;color:var(--ink)}
.r-molecule-body{min-width:0}
.r-molecule-tag{font-family:var(--font-mono);font-size:9.5px;letter-spacing:.32em;color:var(--gold-deep);text-transform:uppercase;font-weight:500;margin-bottom:10px}
.r-molecule-name{font-family:var(--font-display);font-size:clamp(28px,3.5vw,38px);font-weight:300;line-height:1;color:var(--ink);letter-spacing:-.02em;margin-bottom:14px}
.r-molecule-name em{font-style:italic;color:var(--forest);font-weight:400}
.r-molecule-formula{font-family:var(--font-mono);font-size:14px;color:var(--charcoal-soft);margin-bottom:14px;letter-spacing:.04em}
.r-molecule-formula sub{font-size:.78em;line-height:0;vertical-align:sub;color:var(--gold-deep)}
.r-molecule-smiles{font-family:var(--font-mono);font-size:11px;letter-spacing:.04em;color:var(--gold-deep);background:rgba(196,162,101,.06);padding:8px 14px;border:1px solid rgba(196,162,101,.18);display:inline-block;margin-bottom:12px;word-break:break-all}
.r-molecule-cap{font-family:var(--font-kr);font-size:13.5px;line-height:1.7;color:var(--charcoal-mid);font-weight:300}
@media(max-width:640px){.r-molecule{grid-template-columns:1fr;text-align:center}.r-molecule-vis{margin:0 auto}}

/* ━━━━ Methodology 섹션 ━━━━ */
.r-targets{margin-top:42px;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:0;border:var(--rule-strong);background:white;box-shadow:0 1px 0 rgba(196,162,101,.16),0 16px 48px rgba(21,20,15,.04)}
.r-tgrp{padding:24px 26px;border-right:var(--rule-mid)}
.r-tgrp:last-child{border-right:none}
.r-tgrp-disease{font-family:var(--font-display);font-size:18px;font-weight:500;color:var(--ink);margin-bottom:4px;letter-spacing:-.005em}
.r-tgrp-disease em{font-style:italic;color:var(--forest)}
.r-tgrp-en{font-family:var(--font-mono);font-size:9.5px;letter-spacing:.18em;color:var(--charcoal-mid);text-transform:uppercase;margin-bottom:14px;font-weight:500}
.r-tgrp-targets{display:flex;flex-wrap:wrap;gap:6px}
.r-tgrp-target{font-family:var(--font-mono);font-size:11px;padding:4px 10px;background:rgba(45,95,62,.06);color:var(--forest);border:1px solid rgba(45,95,62,.2);letter-spacing:.04em}
.r-tgrp[data-color="gold"] .r-tgrp-target{background:rgba(196,162,101,.06);color:var(--gold-deep);border-color:rgba(196,162,101,.24)}
.r-tgrp[data-color="sage"] .r-tgrp-target{background:rgba(74,140,94,.08);color:var(--sage);border-color:rgba(74,140,94,.22)}
.r-tgrp[data-color="sprout"] .r-tgrp-target{background:rgba(168,197,160,.18);color:var(--forest-deep);border-color:rgba(74,140,94,.22)}
@media(max-width:768px){
  .r-targets{grid-template-columns:1fr}
  .r-tgrp{border-right:none;border-bottom:var(--rule-mid)}
  .r-tgrp:last-child{border-bottom:none}
}

.r-tools{margin-top:42px;display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:0;border:var(--rule-mid);background:var(--paper-shade)}
.r-tool{padding:18px 22px;border-right:var(--rule-soft);border-bottom:var(--rule-soft);background:white;display:grid;grid-template-columns:auto 1fr;gap:14px;align-items:start}
.r-tool-num{font-family:var(--font-display);font-size:22px;font-weight:300;color:var(--gold-deep);line-height:1;letter-spacing:-.02em;font-feature-settings:"onum","ss01";min-width:32px}
.r-tool-body{min-width:0}
.r-tool-name{font-family:var(--font-display);font-size:16px;font-weight:500;color:var(--ink);margin-bottom:4px;letter-spacing:-.005em}
.r-tool-meta{font-family:var(--font-mono);font-size:9.5px;letter-spacing:.18em;color:var(--gold-deep);text-transform:uppercase;font-weight:500;margin-bottom:6px}
.r-tool-meta .lic{color:var(--charcoal-mid);margin-left:8px;letter-spacing:.06em}
.r-tool-role{font-family:var(--font-kr);font-size:13px;line-height:1.6;color:var(--charcoal-mid);font-weight:300}

/* ━━━━ Timeline 섹션 ━━━━ */
.r-timeline{margin-top:42px;position:relative;padding:8px 0}
.r-tl-item{display:grid;grid-template-columns:140px 56px 1fr;gap:24px;padding:22px 0;border-bottom:var(--rule-soft);align-items:start;position:relative}
.r-tl-item:last-child{border-bottom:none}
.r-tl-period{font-family:var(--font-mono);font-size:11px;letter-spacing:.16em;color:var(--charcoal-soft);text-transform:uppercase;font-weight:500;padding-top:6px}
.r-tl-period-label{display:block;font-family:var(--font-display);font-size:11px;font-style:italic;color:var(--gold-deep);font-weight:500;letter-spacing:.06em;margin-top:4px}
.r-tl-marker{display:flex;justify-content:center;position:relative}
.r-tl-marker::before{content:'';position:absolute;top:0;bottom:-22px;left:50%;width:1px;background:var(--gold-deep);opacity:.32}
.r-tl-item:last-child .r-tl-marker::before{display:none}
.r-tl-marker-dot{width:14px;height:14px;border-radius:50%;background:var(--paper);border:2px solid var(--gold-deep);position:relative;z-index:2;margin-top:4px}
.r-tl-item[data-state="done"] .r-tl-marker-dot{background:var(--forest);border-color:var(--forest)}
.r-tl-item[data-state="now"] .r-tl-marker-dot{background:var(--gold);border-color:var(--gold-deep);box-shadow:0 0 0 4px rgba(196,162,101,.18)}
.r-tl-item[data-state="planned"] .r-tl-marker-dot{background:var(--paper);border-color:var(--gold-deep)}
.r-tl-item[data-state="longterm"] .r-tl-marker-dot{background:var(--paper-shade);border-color:rgba(196,162,101,.4);border-style:dashed}
.r-tl-body h4{font-family:var(--font-display);font-size:18px;font-weight:500;color:var(--ink);margin-bottom:6px;letter-spacing:-.005em;line-height:1.4}
.r-tl-body p{font-family:var(--font-kr);font-size:13.5px;line-height:1.7;color:var(--charcoal-mid);font-weight:300}
@media(max-width:640px){
  .r-tl-item{grid-template-columns:auto 1fr;gap:14px}
  .r-tl-period{grid-column:1 / -1;padding-top:0;margin-bottom:6px}
  .r-tl-marker{display:none}
}

/* ━━━━ Institutional logos grid ━━━━ */
.r-inst-grid{margin-top:42px;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1px;background:var(--paper-shade);border:var(--rule-strong);box-shadow:0 1px 0 rgba(196,162,101,.16),0 16px 48px rgba(21,20,15,.04)}
.r-inst{padding:24px 22px;background:white;display:flex;align-items:center;gap:16px;text-decoration:none;border:none;transition:background .35s var(--ease)}
.r-inst:hover{background:var(--paper);border:none}
.r-inst-symbol{font-family:var(--font-display);font-size:28px;color:var(--gold-deep);width:40px;height:40px;border:1px solid var(--gold-deep);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-weight:300;line-height:1}
.r-inst-body{min-width:0}
.r-inst-name{font-family:var(--font-display);font-size:14.5px;font-weight:500;color:var(--ink);margin-bottom:2px;letter-spacing:-.003em;line-height:1.3}
.r-inst-sub{font-family:var(--font-mono);font-size:9.5px;letter-spacing:.06em;color:var(--charcoal-mid);line-height:1.5}

/* Author signature */
.r-author-sig{margin-top:24px;padding:22px 0 4px;border-top:var(--rule-soft);display:flex;align-items:center;gap:18px}
.r-sig-svg{width:130px;height:42px;flex-shrink:0;color:var(--forest)}
.r-sig-svg svg{width:100%;height:100%}
.r-sig-meta{font-family:var(--font-mono);font-size:10px;letter-spacing:.18em;color:var(--charcoal-mid);text-transform:uppercase;line-height:1.7}
.r-sig-meta strong{color:var(--forest);font-weight:500;letter-spacing:.16em}

/* News·Press placeholder */
.r-press{margin-top:42px;padding:28px 32px;background:var(--paper-shade);border:1px dashed rgba(21,20,15,.18);text-align:center}
.r-press-eye{font-family:var(--font-mono);font-size:9.5px;letter-spacing:.32em;color:var(--charcoal-mid);text-transform:uppercase;font-weight:500;margin-bottom:10px}
.r-press p{font-family:var(--font-kr);font-size:14px;color:var(--charcoal-soft);font-weight:300;font-style:italic}

@media print{
  body{background:white;color:black}
  body::after{display:none}
  .r-mast-bar,.r-mast-home,.r-footer-back{display:none}
  .r-prepr,.r-prepr--first{break-inside:avoid;border:1px solid #999;background:white;page-break-inside:avoid}
  .r-prepr:hover{background:white;box-shadow:none}
  .r-section{break-after:auto;page-break-after:auto}
  .r-section-num{color:#999}
  .r-footer{break-before:auto;background:white}
  a{color:black;border-bottom:1px dotted #666}
  .r-prepr-platform{background:white;border-color:#999;color:black}
  .r-mast-mark,.r-section-name h2,.r-prepr-titleko,.r-prepr h3{color:black}
  .r-mast-stat,.r-stat,.r-pillar,.r-tgrp,.r-tool,.r-inst,.r-molecule{break-inside:avoid;page-break-inside:avoid}
  .r-tl-item{break-inside:avoid}
  .r-transparency{break-inside:avoid;background:white;border:1px solid #999}
  /* 페이지 헤더에 쇼트 캡션 */
  @page{margin:18mm 16mm;size:A4;
    @top-right{content:"Recover Research · Vol. I (2026 Q2)";font-family:var(--font-mono);font-size:9px;letter-spacing:.18em;color:#666}
    @bottom-right{content:"page " counter(page);font-family:var(--font-mono);font-size:9px;color:#666}
  }
}
</style>
</head>
<body>

<!-- ━━━ MASTHEAD ━━━ -->
<header class="r-masthead">
  <div class="r-mast-bar">
    <a href="/" class="r-mast-home">
