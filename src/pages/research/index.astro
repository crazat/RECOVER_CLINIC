<!-- ━━━ SECTION IV · PREPRINTS ━━━ -->
<section class="r-section">
  <div class="r-section-head">
    <div class="r-section-num"><em>IV.</em></div>
    <div class="r-section-name">
      <p class="r-section-eye">제4장 · 학술 출판 기록 / Published Records</p>
      <h2>게재 완료 연구 {preprints.length}편<br/><em>Published with DOI</em></h2>
    </div>
  </div>
  <p class="r-section-lede">아래 카드는 Genesis_Medicine Lab에서 작성·게재 완료한 {preprints.length}편의 학술 출판물 abstract입니다. 카드의 표기 형식은 학술 저널 게재 형식을 따르며, 어떠한 임상 효능 주장도 포함하지 않습니다. 영문 abstract는 학술 정확성을 위해 원문 그대로 표기됩니다.</p>

  <div class="r-prepr-list">
    {preprints.map((p: any, idx: number) => {
      const num = idx + 1;
      const isFirst = idx === 0;
      return (
        <article class={`r-prepr ${isFirst ? 'r-prepr--first' : ''}`}>
          <div class="r-prepr-numwrap">
            <div class="r-prepr-num">{String(num).padStart(2, '0')}</div>
            <div class="r-prepr-roman">{toRoman(num)}</div>
            <div class="r-prepr-status">PUBLISHED</div>
          </div>
          <div class="r-prepr-body">
            {p.title_ko && <p class="r-prepr-titleko" set:html={renderMd(p.title_ko)} />}
            <h3 set:html={renderMd(p.title)} />
            <div class="r-prepr-meta">
              <span><span class="lbl">단계:</span> <span class="val">in silico</span></span>
              <span class="sep">·</span>
              <span><span class="lbl">상태:</span> <span class="val">Published</span></span>
              <span class="sep">·</span>
              <span><span class="lbl">라이선스:</span> <span class="val">{p.license}</span></span>
              <span class="sep">·</span>
              <span><span class="lbl">도판:</span> <span class="val">{p.n_figures}</span></span>
              <span class="sep">·</span>
              <span><span class="lbl">단어:</span> <span class="val">{p.word_count_md.toLocaleString()}</span></span>
              {p.publication_date && (
                <>
                  <span class="sep">·</span>
                  <span><span class="lbl">게재:</span> <span class="val">{p.publication_date}</span></span>
                </>
              )}
            </div>
            <p class="r-prepr-abs" set:html={renderMd(p.abstract)} />
            {p.keywords && p.keywords.length > 0 && (
              <div class="r-prepr-keywords">
                <span class="r-prepr-keywords-lbl">Keywords</span>
                {p.keywords.map((k: string) => (
                  <span class="r-prepr-kw">{k}</span>
                ))}
              </div>
            )}
            <div class="r-prepr-foot">
              <span>
                <strong>DOI</strong>
                <a class="doi-active" href={doiUrl(p.doi)} target="_blank" rel="noopener">{p.doi}</a>
              </span>
              <span><strong>Code</strong> <a href={p.code_url} target="_blank" rel="noopener">github.com/crazat/genesis_medicine</a></span>
            </div>
          </div>
        </article>
      );
    })}
  </div>

  <div class="r-transparency">
    <p class="r-transparency-eye">투명성 원칙 · Transparency Shield</p>
    <h3><em>공개</em>를 기본으로 — 외부 검증 가능</h3>
    <p>Genesis_Medicine 연구 코드와 {preprints.length}편의 manuscript 일부는 <a href={codeUrl} target="_blank" rel="noopener">Apache-2.0 라이선스</a>로 공개되어 외부 연구자가 직접 검증 가능한 형태로 운영됩니다. 본 페이지의 모든 활동 기록은 외부 검증 가능성을 뒷받침하는 신뢰 시그니처입니다.</p>
    <div class="r-transparency-meta">
      <a href={codeUrl} target="_blank" rel="noopener">GitHub 보기 →</a>
      <a href={`https://orcid.org/${orcid}`} target="_blank" rel="noopener">ORCID 프로필 →</a>
      <a href="https://www.apache.org/licenses/LICENSE-2.0" target="_blank" rel="noopener">Apache-2.0 라이선스 →</a>
    </div>
  </div>
</section>

<!-- ━━━ SECTION V · TIMELINE ━━━ -->
<section class="r-section">
  <div class="r-section-head">
    <div class="r-section-num"><em>V.</em></div>
    <div class="r-section-name">
      <p class="r-section-eye">제5장 · 연구 일정 / Research Roadmap</p>
      <h2>2026 ~ 2027 + 장기 로드맵<br/><em>학술 출판 → 임상 vertical → 비임상 CRO 검토</em></h2>
    </div>
  </div>
  <p class="r-section-lede">아래 일정은 학술 출판물 작성·게재 → 강남 임상 vertical 가동 → 비임상 CRO 진입 검토의 단계별 로드맵입니다. 미래 일정은 계획이며, 임상 효능을 보장하는 일정이 아닙니다.</p>

  <div class="r-timeline">
    {timeline.map((t) => (
      <div class="r-tl-item" data-state={t.state}>
        <div class="r-tl-period">
          {t.period}
          <span class="r-tl-period-label">{t.label}</span>
        </div>
        <div class="r-tl-marker">
          <span class="r-tl-marker-dot"></span>
        </div>
        <div class="r-tl-body">
          <h4>{t.title}</h4>
          <p>{t.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>

