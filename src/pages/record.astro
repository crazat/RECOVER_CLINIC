---
import MainLayout from '../layouts/MainLayout.astro';
import RecoveryTimelineFigure from '../components/RecoveryTimelineFigure.astro';
---
<MainLayout
  title="회복 기록 | 리커버한의원 강남 — Recovery Records"
  description="회복은 기록으로 남깁니다. Recovery Timeline · 12개 회복 케이스 · 회복 이야기 10편 · 환자 서신으로 보는 리커버 강남의 회복 기록."
  ogTitle="회복 기록 | 리커버한의원 강남"
  ogDescription="회복은 속도가 아니라 기록입니다. 한 사람의 회복 흐름을 단계별로 봅니다."
  active="record"
  chapter="III"
  chapterEyebrow="제 3 장 · Chapter III"
  chapterTitle="회복은 속도가 아니라<br><em>기록</em>입니다"
  chapterTitleEn="Recovery Records · Timeline & Cases"
  chapterCategory="회복 기록"
>
<!-- Recovery Timeline 시점별 미니 일러스트 (Phase F #4) -->
<div style="max-width:1280px;margin:0 auto;padding:0 clamp(20px,5vw,72px)">
  <RecoveryTimelineFigure />
</div>
<section class="timeline section-pad" id="timeline">
  <div class="inner">
    <div class="rv" style="text-align:center"><p class="label" style="justify-content:center">Recovery Journey</p>
      <h2 class="title" style="margin:0 auto 16px">회복의 <em>타임라인</em></h2>
      <p class="desc" style="margin:0 auto;text-align:center">"언제부터 변화가 보이나요?" — 시술 후 90일의 여정을 한눈에.</p></div>

    <!-- 시간 여행 프리뷰 칩 — 클릭하면 해당 단계로 이동 -->
    <div class="tl-preview rv rv-d1" role="tablist" aria-label="회복 타임라인 빠른 이동">
      <p class="tl-preview-lead"><span class="tl-preview-lead-tick"></span>시간 여행 · <em>미리 보기</em></p>
      <div class="tl-chips">
        <button class="tl-chip" data-jump="0" role="tab" aria-selected="false">
          <span class="tl-chip-ico" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.1">
              <ellipse cx="14" cy="17" rx="3.2" ry="1.4" fill="rgba(196,162,101,.2)" stroke="#C4A265"/>
              <path d="M14 15.5v-2.3" stroke="#C4A265"/>
              <circle cx="14" cy="17" r="7" stroke-dasharray="2 3" opacity=".35"/>
            </svg>
          </span>
          <span class="tl-chip-txt">
            <span class="tl-chip-day">Day 1</span>
            <span class="tl-chip-teaser">회복 스위치가 켜지는 순간</span>
          </span>
        </button>
        <button class="tl-chip" data-jump="1" role="tab" aria-selected="false">
          <span class="tl-chip-ico" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.1">
              <path d="M14 22V11" stroke-width="1.3"/>
              <ellipse cx="11.5" cy="14.5" rx="2.5" ry="1.3" transform="rotate(-30 11.5 14.5)" fill="rgba(45,95,62,.12)"/>
              <ellipse cx="16.5" cy="13" rx="2.5" ry="1.3" transform="rotate(30 16.5 13)" fill="rgba(45,95,62,.12)"/>
              <circle cx="14" cy="10" r="1.4" fill="rgba(196,162,101,.35)" stroke="#C4A265"/>
            </svg>
          </span>
          <span class="tl-chip-txt">
            <span class="tl-chip-day">Day 7</span>
            <span class="tl-chip-teaser">"뭔가 달라졌네"를 듣는 시기</span>
          </span>
        </button>
        <button class="tl-chip" data-jump="2" role="tab" aria-selected="false">
          <span class="tl-chip-ico" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.1">
              <path d="M14 24V7" stroke-width="1.3"/>
              <ellipse cx="10" cy="15" rx="3.2" ry="1.6" transform="rotate(-35 10 15)" fill="rgba(45,95,62,.14)"/>
              <ellipse cx="18" cy="13" rx="3.2" ry="1.6" transform="rotate(30 18 13)" fill="rgba(45,95,62,.14)"/>
              <ellipse cx="9.5" cy="10" rx="2.5" ry="1.3" transform="rotate(-40 9.5 10)" fill="rgba(45,95,62,.1)"/>
              <ellipse cx="18.5" cy="9" rx="2.5" ry="1.3" transform="rotate(30 18.5 9)" fill="rgba(45,95,62,.1)"/>
              <circle cx="14" cy="6.5" r="1.6" fill="rgba(196,162,101,.45)" stroke="#C4A265"/>
            </svg>
          </span>
          <span class="tl-chip-txt">
            <span class="tl-chip-day">Day 30</span>
            <span class="tl-chip-teaser">거울 앞에서 스스로 느끼는 변화</span>
          </span>
        </button>
        <button class="tl-chip" data-jump="3" role="tab" aria-selected="false">
          <span class="tl-chip-ico" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.1">
              <path d="M14 25V8" stroke-width="1.3"/>
              <ellipse cx="9.5" cy="17" rx="3.4" ry="1.5" transform="rotate(-30 9.5 17)" fill="rgba(45,95,62,.14)"/>
              <ellipse cx="18.5" cy="15" rx="3.4" ry="1.5" transform="rotate(30 18.5 15)" fill="rgba(45,95,62,.14)"/>
              <g transform="translate(14 7)">
                <ellipse cx="0" cy="-1.8" rx="1.2" ry="2.2" fill="rgba(212,184,122,.5)" stroke="#C4A265" stroke-width=".6"/>
                <ellipse cx="1.8" cy="0" rx="1.2" ry="2.2" transform="rotate(72)" fill="rgba(212,184,122,.5)" stroke="#C4A265" stroke-width=".6"/>
                <ellipse cx="1.1" cy="1.7" rx="1.2" ry="2.2" transform="rotate(144)" fill="rgba(212,184,122,.5)" stroke="#C4A265" stroke-width=".6"/>
                <ellipse cx="-1.1" cy="1.7" rx="1.2" ry="2.2" transform="rotate(216)" fill="rgba(212,184,122,.5)" stroke="#C4A265" stroke-width=".6"/>
                <ellipse cx="-1.8" cy="0" rx="1.2" ry="2.2" transform="rotate(288)" fill="rgba(212,184,122,.5)" stroke="#C4A265" stroke-width=".6"/>
                <circle cx="0" cy="0" r=".9" fill="#C4A265"/>
              </g>
            </svg>
          </span>
          <span class="tl-chip-txt">
            <span class="tl-chip-day">Day 90</span>
            <span class="tl-chip-teaser">본래의 피부 힘이 완성되는 지점</span>
          </span>
        </button>
      </div>
    </div>

    <div class="tl-wrap rv rv-d1">
      <!-- ═══ P2-3 · TIMELINE 좌표축 — 측정 그리드 헤더 ═══ -->
      <div class="tl-axis" aria-hidden="true">
        <span class="tl-axis-coord">[X·TIME]</span>
        <span class="tl-axis-rule"></span>
        <span class="tl-axis-meta">RECOVER RECORD · 회복 기준 기록</span>
      </div>
      <div class="tl-track" id="tlTrack">
        <div class="tl-fill" id="tlFill"></div>
        <div class="tl-labels">
          <span class="tl-label" data-idx="0">Day 1</span>
          <span class="tl-label" data-idx="1">Day 7</span>
          <span class="tl-label" data-idx="2">Day 30</span>
          <span class="tl-label" data-idx="3">Day 90</span>
        </div>
        <div class="tl-points">
          <button class="tl-pt" data-idx="0" data-day="직후" aria-label="Day 1"></button>
          <button class="tl-pt" data-idx="1" data-day="1주" aria-label="Day 7"></button>
          <button class="tl-pt" data-idx="2" data-day="1개월" aria-label="Day 30"></button>
          <button class="tl-pt" data-idx="3" data-day="3개월" aria-label="Day 90"></button>
        </div>
      </div>

      <div class="tl-panel" id="tlPanel">
        <div class="tl-content">
          <p class="tl-day-marker" id="tlMarker">Day 1 · 시술 직후</p>
          <h3 class="tl-headline" id="tlHeadline">몸이 <em>회복 모드</em>로 전환되는 순간</h3>
          <p class="tl-desc" id="tlDesc">시술 부위에 가벼운 자극감이 있을 수 있으나, 대부분의 일상 활동은 정상적으로 가능합니다. 몸 안쪽에서 재생 신호가 이미 시작되고 있습니다.</p>
          <div class="tl-facets">
            <div class="tl-facet">
              <p class="tl-facet-label">체감 변화</p>
              <p class="tl-facet-text" id="tlFeel">가벼운 홍조·압박감이 수 시간 내 완화</p>
            </div>
            <div class="tl-facet">
              <p class="tl-facet-label">내부 작용</p>
              <p class="tl-facet-text" id="tlClinical">콜라겐 합성 신호 활성화 개시</p>
            </div>
          </div>
        </div>
        <div class="tl-visual">
          <div class="tl-vis-ring"></div><div class="tl-vis-ring"></div><div class="tl-vis-ring"></div>
          <div class="tl-stage" id="tlStage">
            <!-- Day 1 — 씨앗 -->
            <svg class="active" data-idx="0" viewBox="0 0 120 120" fill="none" stroke="#2D5F3E" stroke-width="1">
              <circle cx="60" cy="70" r="8" fill="rgba(196,162,101,.15)"/>
              <ellipse cx="60" cy="70" rx="8" ry="3" stroke="#C4A265" stroke-width=".8"/>
              <path d="M60 62v-4" stroke="#C4A265" stroke-width="1"/>
              <path d="M52 66 L48 62M68 66 L72 62" stroke="#8f5229" stroke-width=".5" opacity=".4" stroke-dasharray="1.5 2"/>
              <circle cx="60" cy="70" r="18" stroke-dasharray="2 4" opacity=".25"/>
            </svg>
            <!-- Day 7 — 새순 -->
            <svg data-idx="1" viewBox="0 0 120 120" fill="none" stroke="#2D5F3E" stroke-width="1">
              <path d="M60 80 V50" stroke-width="1.2"/>
              <ellipse cx="56" cy="58" rx="6" ry="3" transform="rotate(-30 56 58)" fill="rgba(45,95,62,.1)" stroke="#2D5F3E"/>
              <ellipse cx="64" cy="55" rx="6" ry="3" transform="rotate(30 64 55)" fill="rgba(45,95,62,.1)" stroke="#2D5F3E"/>
              <ellipse cx="60" cy="82" rx="10" ry="3" stroke="#C4A265" stroke-width=".8"/>
              <circle cx="60" cy="48" r="3" fill="#C4A265" fill-opacity=".3" stroke="#C4A265"/>
            </svg>
            <!-- Day 30 — 잎 무성 -->
            <svg data-idx="2" viewBox="0 0 120 120" fill="none" stroke="#2D5F3E" stroke-width="1">
              <path d="M60 90 V30" stroke-width="1.2"/>
              <ellipse cx="50" cy="60" rx="9" ry="4" transform="rotate(-35 50 60)" fill="rgba(45,95,62,.12)" stroke="#2D5F3E"/>
              <ellipse cx="70" cy="55" rx="9" ry="4" transform="rotate(30 70 55)" fill="rgba(45,95,62,.12)" stroke="#2D5F3E"/>
              <ellipse cx="48" cy="42" rx="7" ry="3" transform="rotate(-40 48 42)" fill="rgba(45,95,62,.1)" stroke="#2D5F3E"/>
              <ellipse cx="72" cy="38" rx="7" ry="3" transform="rotate(25 72 38)" fill="rgba(45,95,62,.1)" stroke="#2D5F3E"/>
              <ellipse cx="60" cy="92" rx="14" ry="3" stroke="#C4A265" stroke-width=".8"/>
              <circle cx="60" cy="28" r="4" fill="#C4A265" fill-opacity=".4" stroke="#C4A265"/>
              <path d="M60 28 L60 22" stroke="#C4A265" stroke-width=".6"/>
            </svg>
            <!-- Day 90 — 꽃 -->
            <svg data-idx="3" viewBox="0 0 120 120" fill="none" stroke="#2D5F3E" stroke-width="1">
              <path d="M60 95 V35" stroke-width="1.2"/>
              <ellipse cx="48" cy="65" rx="10" ry="4" transform="rotate(-30 48 65)" fill="rgba(45,95,62,.14)" stroke="#2D5F3E"/>
              <ellipse cx="72" cy="60" rx="10" ry="4" transform="rotate(30 72 60)" fill="rgba(45,95,62,.14)" stroke="#2D5F3E"/>
              <ellipse cx="46" cy="48" rx="8" ry="3.5" transform="rotate(-40 46 48)" fill="rgba(45,95,62,.12)" stroke="#2D5F3E"/>
              <ellipse cx="74" cy="45" rx="8" ry="3.5" transform="rotate(30 74 45)" fill="rgba(45,95,62,.12)" stroke="#2D5F3E"/>
              <ellipse cx="60" cy="96" rx="16" ry="3.5" stroke="#C4A265" stroke-width=".8"/>
              <!-- 꽃 -->
              <g transform="translate(60 30)">
                <ellipse cx="0" cy="-8" rx="4" ry="7" fill="rgba(212,184,122,.4)" stroke="#C4A265" stroke-width=".7"/>
                <ellipse cx="8" cy="0" rx="4" ry="7" transform="rotate(72)" fill="rgba(212,184,122,.4)" stroke="#C4A265" stroke-width=".7"/>
                <ellipse cx="5" cy="8" rx="4" ry="7" transform="rotate(144)" fill="rgba(212,184,122,.4)" stroke="#C4A265" stroke-width=".7"/>
                <ellipse cx="-5" cy="8" rx="4" ry="7" transform="rotate(216)" fill="rgba(212,184,122,.4)" stroke="#C4A265" stroke-width=".7"/>
                <ellipse cx="-8" cy="0" rx="4" ry="7" transform="rotate(288)" fill="rgba(212,184,122,.4)" stroke="#C4A265" stroke-width=".7"/>
                <circle r="3" fill="#8f5229"/>
              </g>
            </svg>
          </div>
          <span class="tl-vis-caption">Natural Regeneration</span>
        </div>
      </div>

      <div class="tl-controls">
        <button class="tl-play" id="tlPlay" aria-label="자동 재생"><svg viewBox="0 0 10 10" fill="currentColor"><path d="M2 1l7 4-7 4z"/></svg></button>
        <span>90일 자동 재생</span>
      </div>
    </div>
  </div>
</section>

<!-- TIME ESSAY — #13 시간에 대한 관점 -->
<section class="ba-gallery section-pad" id="gallery">
  <div class="inner">
    <div class="rv" style="text-align:center"><p class="label" style="justify-content:center">Recovery Records</p>
      <h2 class="title" style="margin:0 auto 16px">회복의 흐름을 남기는 <em>기록</em></h2>
      <p class="desc" style="margin:0 auto;text-align:center">한 장의 전후 사진이 아니라 어떤 구조를 읽고, 어떤 순서로 회복했는지를 남깁니다.</p></div>
    <div class="ba-filter rv rv-d1" role="tablist" aria-label="후기 필터">
      <button class="ba-chip active" data-f-type="all" data-f-value="all" role="tab" aria-selected="true">전체 <span class="ba-chip-n" data-count="all"></span></button>
      <span class="ba-chip-div"></span>
      <button class="ba-chip" data-f-type="concern" data-f-value="흉터" role="tab">흉터 <span class="ba-chip-n" data-count="concern:흉터"></span></button>
      <button class="ba-chip" data-f-type="concern" data-f-value="붉은기" role="tab">붉은기·홍조 <span class="ba-chip-n" data-count="concern:붉은기"></span></button>
      <button class="ba-chip" data-f-type="concern" data-f-value="리프팅" role="tab">리프팅·주름 <span class="ba-chip-n" data-count="concern:리프팅"></span></button>
      <button class="ba-chip" data-f-type="concern" data-f-value="탄력" role="tab">탄력·결 <span class="ba-chip-n" data-count="concern:탄력"></span></button>
      <span class="ba-chip-div"></span>
      <button class="ba-chip" data-f-type="gender" data-f-value="여성" role="tab">여성 <span class="ba-chip-n" data-count="gender:여성"></span></button>
      <button class="ba-chip" data-f-type="gender" data-f-value="남성" role="tab">남성 <span class="ba-chip-n" data-count="gender:남성"></span></button>
      <span class="ba-chip-div"></span>
      <button class="ba-chip" data-f-type="age" data-f-value="20" role="tab">20대 <span class="ba-chip-n" data-count="age:20"></span></button>
      <button class="ba-chip" data-f-type="age" data-f-value="30" role="tab">30대 <span class="ba-chip-n" data-count="age:30"></span></button>
      <button class="ba-chip" data-f-type="age" data-f-value="40" role="tab">40·50대 <span class="ba-chip-n" data-count="age:40"></span></button>
    </div>
    <p class="ba-filter-status" aria-live="polite"></p>

    <!-- A6 Cinematic Featured Case -->
    <div class="ba-cinema rv rv-d1" id="ba-cinema-feat" data-cinema-src="/assets/ba_skin_lifting_k.webp" aria-label="피처 케이스: 50대 V라인 리프팅">
      <div class="ba-cinema-grid">
        <div class="ba-cinema-narrative">
          <div class="ba-cinema-eyebrow"><span>Featured Case</span><span class="num">No. 037</span></div>
          <h3 class="ba-cinema-title">12주 뒤,<br/><em>턱선이 다시 그려졌다</em></h3>
          <div class="ba-cinema-meta">
            <span>50대 여성 · 주부</span>
            <span>턱선·불독살 처짐</span>
            <span>치료 기간 12주</span>
            <span>새살침 + SMAS 매선</span>
          </div>
          <blockquote class="ba-cinema-quote">
            “거울을 볼 때마다 어머니가 보여서 무서웠어요. 시술 후엔 친구들이 ‘너 뭐 했어?’ 가 아니라 ‘요즘 잘 지내?’ 라고 물어봐요. 그게 더 좋아요.”
            <span class="ba-cinema-quote-author">— 환자 본인 코멘트, 12주차</span>
          </blockquote>
          <div class="ba-cinema-metrics">
            <div class="ba-cinema-metric">
              <div class="ba-cinema-metric-label">턱선 각도</div>
              <div class="ba-cinema-metric-val">132°<em>→112°</em></div>
            </div>
            <div class="ba-cinema-metric">
              <div class="ba-cinema-metric-label">탄력 지수</div>
              <div class="ba-cinema-metric-val">+38<em>%</em></div>
            </div>
            <div class="ba-cinema-metric">
              <div class="ba-cinema-metric-label">처짐 면적</div>
              <div class="ba-cinema-metric-val">−42<em>%</em></div>
            </div>
          </div>
          <p style="font-size:10.5px;color:rgba(255,255,255,.55);letter-spacing:.04em;line-height:1.7;margin-top:14px">* 단일 사례의 RECOVER RECORD 내부 관찰 지표입니다. 측정 기준은 상담 설명용이며 일반화되지 않습니다.</p>
          <div class="ba-cinema-doc">
            <div class="ba-cinema-doc-mark">韓</div>
            <div class="ba-cinema-doc-body">
              <strong>RECOVER NOTE · 회복 기준 해설</strong>
              <p>SMAS층까지 자입한 매선의 장력으로 처진 피부에 지지점을 만들고, 새살침으로 진피 콜라겐 환경을 6개월에 걸쳐 함께 다듬은 사례입니다. 필러 없이 본래의 골격선을 따라가는 회복 흐름을 설계했습니다.</p>
            </div>
          </div>
        </div>
        <div class="ba-cinema-stage" role="slider" tabindex="0" aria-label="좌우로 드래그하여 전후 비교" aria-valuemin="0" aria-valuemax="100" aria-valuenow="50">
          <div class="ba-cinema-layer ba-cinema-after"></div>
          <div class="ba-cinema-layer ba-cinema-before"></div>
          <span class="ba-cinema-corner tl"></span>
          <span class="ba-cinema-corner tr"></span>
          <span class="ba-cinema-corner bl"></span>
          <span class="ba-cinema-corner br"></span>
          <span class="ba-cinema-stamp before">Before<span class="lab-sub">2025.01</span></span>
          <span class="ba-cinema-stamp after">After<span class="lab-sub">2025.04 · 12주</span></span>
          <div class="ba-cinema-divider"></div>
          <div class="ba-cinema-handle" aria-hidden="true"></div>
          <div class="ba-cinema-rail">
            <span class="left">처짐 · 그늘</span>
            <span class="right">선 · 빛</span>
          </div>
          <div class="ba-cinema-counter"><em>01</em>/ FEATURED CASE</div>
        </div>
      </div>
    </div>

    <div class="scroll-nav">
    <button class="scroll-arr left hide" data-target=".ba-grid" aria-label="이전"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg></button>
    <button class="scroll-arr right" data-target=".ba-grid" aria-label="다음"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></button>
    <div class="ba-grid rv rv-d1">
