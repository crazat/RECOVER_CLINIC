{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "firestore.indexes.json",
      ".git/**",
      "**/.*",
      "**/node_modules/**",
      "CLAUDE.md",
      "README.md",
      "recover_gangnam_brand_strategy.md",
      "recover_brand_identity.docx",
      "*.docx",
      "로고 이미지/**",
      "scraps/**",
      "_check/**",
      "screenshots/**",
      "uploads/**",
      "original.html",
      "memory/**"
    ],
    "headers": [
      {
        "source": "**/*.@(png|webp|gif|jpg|jpeg|ico|svg)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/method", "destination": "/index.html" },
      { "source": "/scar", "destination": "/index.html" },
      { "source": "/records", "destination": "/index.html" },
      { "source": "/technology", "destination": "/index.html" },
      { "source": "/consult", "destination": "/index.html" }
    ],
    "cleanUrls": true
  }
}
